<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml" 
      fx:controller="org.example.aideEtdon.backoffice.AideEtdonAlertesAdminController"
      style="-fx-padding: 20; -fx-background-color: transparent;" spacing="20">

    <HBox alignment="CENTER_LEFT" spacing="20">
        <Label text="🚨 Centre d'intervention d'Urgences (Alertes)" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #b91c1c;" />
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="Rafraîchir les Alertes" onAction="#loadAlertes" style="-fx-background-color: #fee2e2; -fx-text-fill: #b91c1c; -fx-font-weight: bold; -fx-padding: 8 16; -fx-background-radius: 6; -fx-cursor: hand;" />
    </HBox>
    
    <Label text="Ce tableau de bord recueille en temps réel toutes les pressions du bouton d'urgence." style="-fx-text-fill: #64748b; -fx-font-size: 14px; -fx-padding: 0 0 10 0;" />

    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-color: transparent;">
        <VBox fx:id="alertesListContainer" spacing="15" style="-fx-padding: 5;" />
    </ScrollPane>

</VBox>
