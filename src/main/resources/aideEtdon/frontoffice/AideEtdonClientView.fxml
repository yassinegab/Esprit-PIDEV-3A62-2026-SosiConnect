<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.example.aideEtdon.frontoffice.controller.AideEtdonControllerClientController"
            prefHeight="600.0" prefWidth="800.0"
            stylesheets="@aide_styles.css"
            style="-fx-background-color: #f8fafc;">

    <!-- Top Navigation Bar -->
    <top>
        <HBox alignment="CENTER" spacing="40" styleClass="top-nav-container">
            <Button fx:id="btnAides" text="Aides" onAction="#showAides" styleClass="top-nav-button-active" />
            <Button fx:id="btnDons" text="Dons" onAction="#showDons" styleClass="top-nav-button" />
        </HBox>
    </top>

    <!-- Center Content Area -->
    <center>
        <StackPane fx:id="contentArea" style="-fx-padding: 30;" BorderPane.alignment="CENTER">
            <!-- Content will be injected dynamically by controller -->
        </StackPane>
    </center>
</BorderPane>
