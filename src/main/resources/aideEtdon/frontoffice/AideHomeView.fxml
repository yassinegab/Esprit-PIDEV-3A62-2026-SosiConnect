<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<ScrollPane fitToWidth="true" fitToHeight="true" xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml" 
            fx:controller="org.example.aideEtdon.frontoffice.controller.AideHomeController" 
            stylesheets="@aide_styles.css"
            styleClass="transparent-scroll">

    <VBox spacing="20" style="-fx-padding: 30; -fx-background-color: transparent;">

        <HBox alignment="CENTER_LEFT" spacing="20">
            <VBox>
                <Label text="Statut Actuel" styleClass="page-subtitle"/>
                <Label fx:id="statusIndicator" text="NORMAL" styleClass="status-indicator" />
            </VBox>
            <Region HBox.hgrow="ALWAYS" />
            <Button text="Configurer Contact(s)" onAction="#goToContactForm" styleClass="config-button" />
        </HBox>

        <HBox spacing="30" VBox.vgrow="ALWAYS">
            <VBox spacing="30" HBox.hgrow="ALWAYS" alignment="CENTER" styleClass="aide-card">
                
                <Label text="De quoi avez-vous besoin ?" styleClass="page-title" />
                
                <HBox spacing="15" alignment="CENTER">
                    <ToggleButton fx:id="btnMed" text="💊 Médicaments" styleClass="peril-toggle" />
                    <ToggleButton fx:id="btnDanger" text="🛒 Courses / Quotidien" styleClass="peril-toggle" />
                    <ToggleButton fx:id="btnOther" text="🩺 Assistance Médicale" styleClass="peril-toggle" />
                </HBox>
                
                <CheckBox fx:id="chkLocation" text="Inclure ma position (GPS / Domicile)" styleClass="location-checkbox" />

                <Region prefHeight="20" />

                <StackPane>
                    <Button fx:id="btnEmergency" text="🚨 DEMANDER L'AIDE MAINTENANT" onAction="#handleEmergencyAction" styleClass="emergency-button" />
                </StackPane>

                <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-padding: 10 0 0 0;">
                    <Label text="Rechercher à proximité :" style="-fx-font-weight: bold; -fx-text-fill: #475569;" />
                    <ComboBox fx:id="mapFilterCombo" prefWidth="250" style="-fx-background-color: #f8fafc; -fx-border-color: #cbd5e1; -fx-border-radius: 6; -fx-background-radius: 6;" />
                </HBox>

                <VBox fx:id="mapContainer" prefHeight="300.0" VBox.vgrow="ALWAYS" />

            </VBox>

            <VBox spacing="15" prefWidth="350" styleClass="aide-card">
                <Label text="Historique des Alertes" styleClass="section-title" />
                <ListView fx:id="historyList" VBox.vgrow="ALWAYS" styleClass="history-list" />
            </VBox>
        </HBox>

    </VBox>

</ScrollPane>
