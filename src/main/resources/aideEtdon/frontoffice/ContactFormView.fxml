<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<ScrollPane fitToWidth="true" fitToHeight="true" xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml" 
            fx:controller="org.example.aideEtdon.frontoffice.controller.ContactFormController" 
            stylesheets="@aide_styles.css"
            styleClass="transparent-scroll">

    <VBox alignment="CENTER" spacing="30" style="-fx-padding: 40; -fx-background-color: transparent;">

        <VBox spacing="10" alignment="CENTER">
            <Label text="Gestion des Contacts de Confiance" styleClass="page-title" />
            <Label text="Ces personnes seront alertées en cas de besoin absolu." styleClass="page-subtitle" />
        </VBox>

        <HBox spacing="40" alignment="TOP_CENTER" VBox.vgrow="ALWAYS">
            
            <!-- Left Side: Form to ADD or UPDATE -->
            <VBox spacing="20" prefWidth="450" styleClass="aide-card">
                <Label fx:id="formTitleLabel" text="Ajouter un contact" styleClass="section-title" />
                <VBox spacing="8">
                    <Label text="Nom complet *" styleClass="form-label" />
                    <TextField fx:id="fldNom" promptText="Ex: Jean" styleClass="modern-input" />
                </VBox>
                <VBox spacing="8">
                    <Label text="Email *" styleClass="form-label" />
                    <TextField fx:id="fldEmail" promptText="Ex: jean@email.com" styleClass="modern-input" />
                </VBox>
                <VBox spacing="8">
                    <Label text="Téléphone" styleClass="form-label" />
                    <TextField fx:id="fldTel" promptText="06..." styleClass="modern-input" />
                </VBox>
                
                <Label fx:id="lblError" text="Veuillez remplir le Nom et l'Email." style="-fx-font-size: 16px;" textFill="red" visible="false" />
                
                <HBox spacing="10">
                    <Button fx:id="btnSave" text="💾 ENREGISTRER" onAction="#handleSave" HBox.hgrow="ALWAYS" maxWidth="Infinity" styleClass="primary-action-button" />
                    <Button fx:id="btnCancelEdit" text="✖" visible="false" onAction="#cancelEdit" styleClass="secondary-action-button" />
                </HBox>
            </VBox>

            <!-- Right Side: List of Contacts -->
            <VBox spacing="20" HBox.hgrow="ALWAYS" styleClass="aide-card">
                <Label text="Contacts Enregistrés" styleClass="success-title" />
                <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" styleClass="transparent-scroll">
                    <VBox fx:id="contactsContainer" spacing="15.0" style="-fx-padding: 5;" />
                </ScrollPane>
            </VBox>

        </HBox>

        <Button text="← Retour au Bouton" onAction="#goBack" styleClass="go-back-button" />

    </VBox>

</ScrollPane>
