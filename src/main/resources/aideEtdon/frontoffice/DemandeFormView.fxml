<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.collections.FXCollections?>
<?import java.lang.String?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="org.example.aideEtdon.frontoffice.controller.DemandeFormController"
      alignment="TOP_CENTER" spacing="30.0"
      stylesheets="@don_styles.css"
      styleClass="main-bg">

    <StackPane>
        <HBox alignment="CENTER_LEFT">
            <Button text="← Retour" onAction="#handleRetour" styleClass="back-button" />
        </HBox>
        <Label text="Nouvelle Demande" styleClass="page-title" StackPane.alignment="CENTER" />
    </StackPane>
    
    <Label fx:id="errorLabel" visible="false" text="Veuillez remplir tous les champs obligatoires!" style="-fx-text-fill: #ef4444; -fx-font-weight: bold;" />

    <ScrollPane fitToWidth="true" fitToHeight="true" style="-fx-background-color: transparent; -fx-background: transparent;" VBox.vgrow="ALWAYS">
        <VBox alignment="TOP_CENTER" style="-fx-padding: 5;">
            <VBox spacing="20.0" maxWidth="550" styleClass="form-card">
        
        <VBox spacing="8.0">
            <Label text="Titre *" styleClass="label-title" />
            <TextField fx:id="titreField" promptText="Ex: Besoin urgent de sang O-" styleClass="modern-input" />
        </VBox>

        <VBox spacing="8.0">
            <Label text="Description *" styleClass="label-title" />
            <TextArea fx:id="descriptionArea" promptText="Décrivez votre besoin..." prefRowCount="4" styleClass="modern-input" wrapText="true" />
        </VBox>

        <HBox spacing="20.0">
            <VBox spacing="8.0" HBox.hgrow="ALWAYS">
                <Label text="Type de Don *" styleClass="label-title" />
                <ComboBox fx:id="typeBox" maxWidth="Infinity" styleClass="modern-input">
                    <items>
                        <FXCollections fx:factory="observableArrayList">
                            <String fx:value="Sang" />
                            <String fx:value="Organe" />
                            <String fx:value="Autre" />
                        </FXCollections>
                    </items>
                </ComboBox>
            </VBox>

            <VBox fx:id="groupeSanguinContainer" spacing="8.0" HBox.hgrow="ALWAYS" visible="false" managed="false">
                <Label text="Groupe Sanguin *" styleClass="label-title" />
                <TextField fx:id="groupeSanguinField" promptText="Ex: AB+" styleClass="modern-input" />
            </VBox>

            <VBox fx:id="organeContainer" spacing="8.0" HBox.hgrow="ALWAYS" visible="false" managed="false">
                <Label text="Organe *" styleClass="label-title" />
                <TextField fx:id="organeField" promptText="Ex: Rein" styleClass="modern-input" />
            </VBox>
        </HBox>

        <VBox spacing="8.0">
            <Label text="Niveau d'urgence *" styleClass="label-title" />
            <ComboBox fx:id="urgenceBox" maxWidth="Infinity" styleClass="modern-input">
                <items>
                    <FXCollections fx:factory="observableArrayList">
                        <String fx:value="Normal" />
                        <String fx:value="Urgent" />
                    </FXCollections>
                </items>
            </ComboBox>
        </VBox>

        <Region prefHeight="10.0" />
        <Button text="Valider la demande" onAction="#handleValider" maxWidth="Infinity" styleClass="primary-button" />

            </VBox>
        </VBox>
    </ScrollPane>
</VBox>
