<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.Tooltip?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.image.Image?>
<?import java.net.URL?>

<BorderPane prefHeight="820.0" prefWidth="1280.0"
            styleClass="admin-root"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.example.backoffice.controller.AdminBaseController">

    <stylesheets>
        <URL value="@admin_style.css"/>
    </stylesheets>

    <!-- ═══════════════════════════════════════ -->
    <!--  ICON-ONLY SIDEBAR (left, 64px)         -->
    <!-- ═══════════════════════════════════════ -->
    <left>
        <VBox styleClass="sidebar" alignment="CENTER" BorderPane.alignment="CENTER">

            <!-- Logo Section -->
            <StackPane styleClass="sidebar-logo-container">
                <ImageView fitWidth="32" preserveRatio="true">
                    <Image url="@../assets/images/sosi_logo.png" />
                </ImageView>
            </StackPane>

            <!-- Thin separator -->
            <Region styleClass="sidebar-separator"/>

            <!-- Nav icons (fills remaining vertical space) -->
            <VBox VBox.vgrow="ALWAYS" alignment="TOP_CENTER" spacing="6" style="-fx-padding: 8 0;">
                <Button fx:id="btnDashboard" styleClass="icon-nav-btn,active" onAction="#showDashboard">
                    <tooltip><Tooltip text="Dashboard"/></tooltip>
                    <graphic><Label text="📊" styleClass="icon-nav-glyph"/></graphic>
                </Button>
                <Button fx:id="btnUsers" styleClass="icon-nav-btn" onAction="#showUserAdmin">
                    <tooltip><Tooltip text="Utilisateurs"/></tooltip>
                    <graphic><Label text="👥" styleClass="icon-nav-glyph"/></graphic>
                </Button>

                <!-- divider dot -->
                <Region styleClass="icon-nav-divider"/>

                <Button fx:id="btnWellbeing" styleClass="icon-nav-btn" onAction="#showWellbeingAdmin">
                    <tooltip><Tooltip text="Bien-être Mental"/></tooltip>
                    <graphic><Label text="🧠" styleClass="icon-nav-glyph"/></graphic>
                </Button>
                <Button fx:id="btnMedical" styleClass="icon-nav-btn" onAction="#showMedicalAdmin">
                    <tooltip><Tooltip text="Services Médicaux"/></tooltip>
                    <graphic><Label text="⚕" styleClass="icon-nav-glyph"/></graphic>
                </Button>
                <Button fx:id="btnAide" styleClass="icon-nav-btn" onAction="#showAideAdmin">
                    <tooltip><Tooltip text="Aide &amp; Don"/></tooltip>
                    <graphic><Label text="🤝" styleClass="icon-nav-glyph"/></graphic>
                </Button>
                <Button fx:id="btnCycle" styleClass="icon-nav-btn" onAction="#showCycleAdmin">
                    <tooltip><Tooltip text="Suivi Cycle"/></tooltip>
                    <graphic><Label text="🌸" styleClass="icon-nav-glyph"/></graphic>
                </Button>
            </VBox>

            <!-- Bottom: logout -->
            <Region styleClass="sidebar-separator"/>
            <Button styleClass="icon-nav-btn,logout-icon-btn" onAction="#handleLogout">
                <tooltip><Tooltip text="Déconnexion"/></tooltip>
                <graphic><Label text="⏻" styleClass="icon-nav-glyph"/></graphic>
            </Button>
            <VBox.margin>
                <Insets bottom="12"/>
            </VBox.margin>
        </VBox>
    </left>

    <!-- ═══════════════════════════════════════ -->
    <!--  RIGHT SIDE: top bar + content          -->
    <!-- ═══════════════════════════════════════ -->
    <center>
        <VBox spacing="0">

            <!-- Top Bar -->
            <HBox styleClass="admin-topbar" alignment="CENTER_LEFT" spacing="16">
                <padding><Insets left="28" right="28"/></padding>

                <!-- Search pill (grows) -->
                <HBox styleClass="admin-search-pill" alignment="CENTER_LEFT" spacing="8" HBox.hgrow="ALWAYS">
                    <Label text="🔍" styleClass="admin-search-icon"/>
                    <TextField promptText="Rechercher dans le système…"
                               styleClass="admin-search-field"
                               maxWidth="Infinity" HBox.hgrow="ALWAYS"/>
                </HBox>

                <Region HBox.hgrow="ALWAYS"/>

                <Button styleClass="admin-icon-btn" text="🔔"/>
                <Button styleClass="admin-icon-btn" text="⚙"/>

                <Region styleClass="admin-v-divider"/>

                <!-- Admin profile chip -->
                <HBox styleClass="admin-profile-chip" alignment="CENTER" spacing="10">
                    <StackPane styleClass="admin-avatar-circle">
                        <Label text="AD" styleClass="admin-avatar-letters"/>
                    </StackPane>
                    <VBox alignment="CENTER_LEFT" spacing="0">
                        <Label text="Admin User"           styleClass="admin-profile-name"/>
                        <Label text="Super Administrateur" styleClass="admin-profile-role"/>
                    </VBox>
                </HBox>
            </HBox>

            <!-- Dynamic Content Area -->
            <StackPane fx:id="adminContentArea" VBox.vgrow="ALWAYS" styleClass="admin-content-area"/>
        </VBox>
    </center>

</BorderPane>
