<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox prefHeight="700.0" prefWidth="950.0" style="-fx-background-color: #fcfbfd;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.cycle.frontoffice.controller.CycleHistoryController">

    <stylesheets>
        <URL value="@DisplayCss.css" />
    </stylesheets>

    <!-- HEADER SECTION -->
    <HBox style="-fx-background-color: white; -fx-padding: 20 30; -fx-border-color: #f1f2f6; -fx-border-width: 0 0 1 0; -fx-alignment: center-left;">
        <VBox>
            <Label style="-fx-font-size: 22px; -fx-font-weight: 800; -fx-text-fill: #1e293b;" text="⏳ Historique Chronologique" />
            <Label style="-fx-font-size: 14px; -fx-text-fill: #64748b;" text="Analyse détaillée de vos précédents cycles" />
        </VBox>
    </HBox>

    <!-- CONTENT SECTION (Dense chronological list) -->
    <ScrollPane fitToWidth="true" hbarPolicy="NEVER" pannable="true" style="-fx-background-color: transparent; -fx-background: #fcfbfd;" vbarPolicy="AS_NEEDED" VBox.vgrow="ALWAYS">
        <content>
            <VBox fx:id="historyContainer" alignment="TOP_CENTER" spacing="20" style="-fx-padding: 30;">
                <!-- Dynamically populated in Controller -->
            </VBox>
        </content>
    </ScrollPane>

</VBox>
