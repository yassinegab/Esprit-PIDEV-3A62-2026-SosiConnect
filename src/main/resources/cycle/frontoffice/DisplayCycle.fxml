<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.VBox?>

<VBox prefHeight="600.0" prefWidth="900.0" styleClass="main-container" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.cycle.frontoffice.controller.DisplayCycleController">

    <stylesheets>
        <URL value="@DisplayCss.css" />
    </stylesheets>

    <!-- HEADER SECTION -->
    <HBox styleClass="header-container" alignment="CENTER_LEFT">
        <VBox>
            <Label styleClass="header-title" text="Mes Cycles Menstruels" />
            <HBox spacing="10">
                <Button fx:id="btnPdf" onAction="#exportToPdf" styleClass="btn-secondary" text="Exporter PDF" />
                <Button fx:id="btnStats" onAction="#goToStats" styleClass="btn-secondary" text="Statistiques" />
                <Button fx:id="btnCharts" onAction="#goToCharts" styleClass="btn-secondary" text="Graphiques" />
                <Button fx:id="btnHistory" onAction="#goToHistory" styleClass="btn-secondary" text="Historique" />
                <Button fx:id="btnSymptomes" onAction="#goToSymptomes" styleClass="btn-secondary" text="Voir Symptômes" />
            </HBox>
        </VBox>
        
        <!-- PUSH BUTTONS TO RIGHT -->
        <Pane HBox.hgrow="ALWAYS" />
        
        <HBox spacing="10" alignment="CENTER_RIGHT">
            <Button fx:id="navtoaddcycle" onAction="#goToAddCycle" styleClass="btn-primary" text="+ Nouveau Cycle" />
        </HBox>
    </HBox>

    <!-- CONTENT SECTION -->
    <ScrollPane fx:id="scrollPane" fitToWidth="true" hbarPolicy="NEVER" pannable="true" styleClass="custom-scroll" vbarPolicy="AS_NEEDED" VBox.vgrow="ALWAYS">
        <content>
            <VBox alignment="TOP_CENTER" spacing="15">
                <!-- 🔥 CYCLES CONTAINER -->
                <FlowPane fx:id="cycleContainer" hgap="25" prefWrapLength="850" styleClass="cycle-container" vgap="25" />
            </VBox>
        </content>
    </ScrollPane>

</VBox>
