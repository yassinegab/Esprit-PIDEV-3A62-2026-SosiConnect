<?xml version="1.0" encoding="UTF-8"?>
<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.VBox?>

<VBox prefHeight="700.0" prefWidth="950.0" style="-fx-background-color: #fcfbfd;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.cycle.frontoffice.controller.DisplayCycleController">

    <stylesheets>
        <URL value="@DisplayCss.css" />
    </stylesheets>

    <!-- HEADER SECTION -->
    <HBox style="-fx-background-color: white; -fx-padding: 15 25 15 25; -fx-border-color: #f1f2f6; -fx-border-width: 0 0 1 0; -fx-alignment: center-left;" spacing="20">
        <VBox spacing="5">
            <Label style="-fx-font-size: 24px; -fx-font-weight: 800; -fx-text-fill: #1e293b;" text="🌸 Mon Tableau de Bord" />
            <Label fx:id="lblWelcome" style="-fx-font-size: 14px; -fx-text-fill: #64748b;" text="Suivi menstruel et prédictions globales" />
        </VBox>
        
        <Pane HBox.hgrow="ALWAYS" />
        
        <HBox spacing="12" alignment="CENTER_RIGHT">
            <Button fx:id="navtoaddcycle" onAction="#goToAddCycle" style="-fx-background-color: #ff6b81; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 20; -fx-padding: 10 20; -fx-effect: dropshadow(three-pass-box, rgba(255,107,129,0.3), 10, 0, 0, 5); -fx-cursor: hand;" text="+ Nouveau Cycle" />
            <Button fx:id="btnPdf" onAction="#exportToPdf" style="-fx-background-color: white; -fx-text-fill: #475569; -fx-border-color: #cbd5e1; -fx-border-radius: 20; -fx-background-radius: 20; -fx-padding: 9 19; -fx-cursor: hand;" text="Exporter PDF" />
        </HBox>
    </HBox>
    
    <!-- NAVIGATION TABS -->
    <HBox style="-fx-padding: 15 25; -fx-background-color: transparent;" spacing="15" alignment="CENTER_LEFT">
        <Button fx:id="btnStats" onAction="#goToStats" styleClass="btn-tab" text="📊 Statistiques" />
        <Button fx:id="btnCharts" onAction="#goToCharts" styleClass="btn-tab" text="📈 Graphiques" />
        <Button fx:id="btnHistory" onAction="#goToHistory" styleClass="btn-tab" text="⏳ Historique" />
        <Button fx:id="btnSymptomes" onAction="#goToSymptomes" styleClass="btn-tab" text="🤒 Symptômes" />
        <Button fx:id="btnCalendar" onAction="#goToCalendar" styleClass="btn-tab" text="📅 Calendrier Interactif" />
    </HBox>

    <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: #fcfbfd;" vbarPolicy="AS_NEEDED" hbarPolicy="NEVER" VBox.vgrow="ALWAYS">
        <VBox spacing="25" style="-fx-padding: 10 30 30 30;">
        
            <!-- ALERTS SECTION -->
            <VBox fx:id="alertBox" style="-fx-background-color: #fff1f2; -fx-background-radius: 12; -fx-padding: 15; -fx-border-color: #ffe4e6; -fx-border-radius: 12; -fx-border-width: 1;" visible="false" managed="false">
                <Label fx:id="lblAlertMsg" style="-fx-text-fill: #e11d48; -fx-font-weight: bold; -fx-font-size: 14px;" text="⚠️ Cycle Instable Détecté : Vos cycles varient de manière anormale." />
            </VBox>

            <!-- MAIN PREDICTION HERO CARD -->
            <HBox spacing="25">
                <VBox style="-fx-background-color: linear-gradient(to bottom right, #ff9a9e, #fecfef); -fx-background-radius: 24; -fx-padding: 30; -fx-effect: dropshadow(three-pass-box, rgba(255,154,158,0.4), 20, 0, 0, 10);" HBox.hgrow="ALWAYS" prefWidth="400">
                    <Label style="-fx-text-fill: white; -fx-font-size: 16px; -fx-font-weight: bold; -fx-opacity: 0.9;" text="Prochaines Règles Est." />
                    <Label fx:id="lblNextPeriod" style="-fx-text-fill: white; -fx-font-size: 36px; -fx-font-weight: 900;" text="12 Nov 2026" />
                    <HBox alignment="BOTTOM_LEFT" VBox.vgrow="ALWAYS">
                        <Label fx:id="lblDaysRemaining" style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold; -fx-background-color: rgba(0,0,0,0.1); -fx-padding: 5 15; -fx-background-radius: 15; -fx-translate-y: 10;" text="Dans 4 jours" />
                    </HBox>
                </VBox>
                
                <VBox style="-fx-background-color: white; -fx-background-radius: 24; -fx-padding: 25; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.04), 15, 0, 0, 5);" HBox.hgrow="ALWAYS" prefWidth="300" spacing="10" alignment="CENTER_LEFT">
                    <HBox alignment="CENTER_LEFT" spacing="15">
                        <Label style="-fx-font-size: 30px;" text="🩷" />
                        <VBox>
                            <Label style="-fx-text-fill: #64748b; -fx-font-size: 13px;" text="Jour d'Ovulation" />
                            <Label fx:id="lblOvulation" style="-fx-text-fill: #1e293b; -fx-font-size: 20px; -fx-font-weight: bold;" text="14 Oct" />
                        </VBox>
                    </HBox>
                    <Pane style="-fx-background-color: #f1f5f9; -fx-pref-height: 1;" />
                    <HBox alignment="CENTER_LEFT" spacing="15">
                        <Label style="-fx-font-size: 30px;" text="🩵" />
                        <VBox>
                            <Label style="-fx-text-fill: #64748b; -fx-font-size: 13px;" text="Fenêtre Fertile" />
                            <Label fx:id="lblFertile" style="-fx-text-fill: #1e293b; -fx-font-size: 16px; -fx-font-weight: bold;" text="09 Oct - 15 Oct" />
                        </VBox>
                    </HBox>
                </VBox>
            </HBox>

            <!-- SECONDARY KPIs -->
            <HBox spacing="20">
                <VBox style="-fx-background-color: white; -fx-background-radius: 16; -fx-padding: 20; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.03), 10, 0, 0, 4);" HBox.hgrow="ALWAYS" alignment="CENTER">
                    <Label style="-fx-text-fill: #94a3b8; -fx-font-size: 14px;" text="Durée Moyenne Cycle" />
                    <Label fx:id="lblAvgCycle" style="-fx-text-fill: #1e293b; -fx-font-size: 28px; -fx-font-weight: 800;" text="28 j" />
                </VBox>
                
                <VBox style="-fx-background-color: white; -fx-background-radius: 16; -fx-padding: 20; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.03), 10, 0, 0, 4);" HBox.hgrow="ALWAYS" alignment="CENTER">
                    <Label style="-fx-text-fill: #94a3b8; -fx-font-size: 14px;" text="Durée Moyenne Règles" />
                    <Label fx:id="lblAvgMenstruation" style="-fx-text-fill: #1e293b; -fx-font-size: 28px; -fx-font-weight: 800;" text="5 j" />
                </VBox>
                
                <VBox style="-fx-background-color: white; -fx-background-radius: 16; -fx-padding: 20; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.03), 10, 0, 0, 4);" HBox.hgrow="ALWAYS" alignment="CENTER">
                    <Label style="-fx-text-fill: #94a3b8; -fx-font-size: 14px;" text="Stabilité" />
                    <Label fx:id="lblRegularity" style="-fx-text-fill: #10b981; -fx-font-size: 28px; -fx-font-weight: 800;" text="95%" />
                </VBox>
            </HBox>
            
        </VBox>
    </ScrollPane>

</VBox>
