<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.web.WebView?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.Button?>

<VBox xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml" fx:controller="org.example.event.frontoffice.controller.MapController" prefHeight="500.0" prefWidth="700.0" spacing="10" style="-fx-background-color: white; -fx-padding: 10;">
    
    <HBox alignment="CENTER_LEFT" spacing="10">
        <Label text="📍 Localisation de l'événement" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1e293b;" HBox.hgrow="ALWAYS" maxWidth="Infinity" />
        <Button text="Fermer" onAction="#closeWindow" style="-fx-background-color: #ef4444; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 5; -fx-cursor: hand;" />
    </HBox>
    
    <Label fx:id="lblAddress" style="-fx-text-fill: #64748b; -fx-font-size: 14px; -fx-wrap-text: true;" />
    
    <WebView fx:id="webView" VBox.vgrow="ALWAYS" />

</VBox>
