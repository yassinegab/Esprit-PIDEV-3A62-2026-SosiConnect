<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<ScrollPane fitToWidth="true"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.example.servicesociaux.backoffice.controllers.HopitalController"
            style="-fx-background-color: #f0f2f7; -fx-background: #f0f2f7;
                   -fx-border-color: transparent;">

    <VBox spacing="0" style="-fx-background-color: #f0f2f7; -fx-min-height: 700;">

        <!-- ═══ HEADER ═══════════════════════════════════════════ -->
        <HBox alignment="CENTER_LEFT" spacing="12"
              style="-fx-background-color: #1a2744; -fx-padding: 14 22;">
            <Button text="←" onAction="#retourAccueil"
                    style="-fx-background-color: rgba(58,123,213,0.25);
                           -fx-text-fill: #7ab3f0;
                           -fx-background-radius: 50;
                           -fx-font-size: 14; -fx-font-weight: bold;
                           -fx-padding: 4 13;
                           -fx-border-color: rgba(58,123,213,0.4);
                           -fx-border-radius: 50; -fx-cursor: hand;"/>
            <Label text="🏥  Gestion des Hôpitaux — Administration"
                   style="-fx-font-size: 14; -fx-font-weight: bold;
                          -fx-text-fill: white;" HBox.hgrow="ALWAYS"/>
            <Label text="⚙ Backoffice"
                   style="-fx-text-fill: rgba(255,255,255,0.35); -fx-font-size: 10;"/>
        </HBox>

        <VBox spacing="12" style="-fx-padding: 16 20;">

            <!-- ═══ STATISTIQUES ══════════════════════════════════ -->
            <HBox spacing="10">

                <VBox HBox.hgrow="ALWAYS"
                      style="-fx-background-color: white;
                             -fx-border-color: #3a7bd5, #dde3f0, #dde3f0, #3a7bd5;
                             -fx-border-width: 0.5 0.5 0.5 4;
                             -fx-background-radius: 10; -fx-border-radius: 0 10 10 0;
                             -fx-padding: 11 14;" spacing="2" alignment="CENTER_LEFT">
                    <Label text="TOTAL HÔPITAUX"
                           style="-fx-font-size: 9; -fx-font-weight: bold; -fx-text-fill: #999;"/>
                    <Label fx:id="statTotalHopitaux" text="0"
                           style="-fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: #1a2744;"/>
                    <Label text="établissements"
                           style="-fx-font-size: 9; -fx-text-fill: #bbb;"/>
                </VBox>

                <VBox HBox.hgrow="ALWAYS"
                      style="-fx-background-color: white;
                             -fx-border-color: #1ea064, #dde3f0, #dde3f0, #1ea064;
                             -fx-border-width: 0.5 0.5 0.5 4;
                             -fx-background-radius: 10; -fx-border-radius: 0 10 10 0;
                             -fx-padding: 11 14;" spacing="2" alignment="CENTER_LEFT">
                    <Label text="AVEC URGENCE"
                           style="-fx-font-size: 9; -fx-font-weight: bold; -fx-text-fill: #999;"/>
                    <Label fx:id="statUrgence" text="0"
                           style="-fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: #1a2744;"/>
                    <Label text="service urgence dispo"
                           style="-fx-font-size: 9; -fx-text-fill: #bbb;"/>
                </VBox>

                <VBox HBox.hgrow="ALWAYS"
                      style="-fx-background-color: white;
                             -fx-border-color: #7b5ea7, #dde3f0, #dde3f0, #7b5ea7;
                             -fx-border-width: 0.5 0.5 0.5 4;
                             -fx-background-radius: 10; -fx-border-radius: 0 10 10 0;
                             -fx-padding: 11 14;" spacing="2" alignment="CENTER_LEFT">
                    <Label text="TOTAL RDV"
                           style="-fx-font-size: 9; -fx-font-weight: bold; -fx-text-fill: #999;"/>
                    <Label fx:id="statTotalRdv" text="0"
                           style="-fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: #1a2744;"/>
                    <Label text="rendez-vous enregistrés"
                           style="-fx-font-size: 9; -fx-text-fill: #bbb;"/>
                </VBox>

                <VBox HBox.hgrow="ALWAYS"
                      style="-fx-background-color: white;
                             -fx-border-color: #e09030, #dde3f0, #dde3f0, #e09030;
                             -fx-border-width: 0.5 0.5 0.5 4;
                             -fx-background-radius: 10; -fx-border-radius: 0 10 10 0;
                             -fx-padding: 11 14;" spacing="2" alignment="CENTER_LEFT">
                    <Label text="EN ATTENTE"
                           style="-fx-font-size: 9; -fx-font-weight: bold; -fx-text-fill: #999;"/>
                    <Label fx:id="statEnAttente" text="0"
                           style="-fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: #1a2744;"/>
                    <Label text="à traiter"
                           style="-fx-font-size: 9; -fx-text-fill: #e09030;"/>
                </VBox>

            </HBox>

            <!-- ═══ LAYOUT : FORMULAIRE | TABLEAU ════════════════ -->
            <HBox spacing="12" VBox.vgrow="ALWAYS">

                <!-- ── FORMULAIRE (gauche) ───────────────────────── -->
                <ScrollPane fitToWidth="true" prefWidth="290" minWidth="270"
                            style="-fx-background-color: transparent;
                                   -fx-background: transparent;
                                   -fx-border-color: transparent;">
                    <VBox spacing="10"
                          style="-fx-background-color: white;
                                 -fx-border-color: #dde3f0; -fx-border-width: 0.5;
                                 -fx-border-radius: 10; -fx-background-radius: 10;
                                 -fx-padding: 14;">

                        <Label text="Formulaire hôpital"
                               style="-fx-font-size: 12; -fx-font-weight: bold;
                                      -fx-text-fill: #1a2744;"/>
                        <Label text="Sélectionnez une ligne ou créez un nouvel hôpital"
                               style="-fx-font-size: 9; -fx-text-fill: #aaa;"
                               wrapText="true"/>

                        <Region prefHeight="2"
                                style="-fx-background-color: #f0f2f7;"/>

                        <!-- Nom * -->
                        <VBox spacing="3">
                            <Label text="Nom *"
                                   style="-fx-font-size: 10; -fx-font-weight: bold;
                                          -fx-text-fill: #555;"/>
                            <TextField fx:id="fieldNom"
                                       promptText="ex: CHU Tunis"
                                       style="-fx-background-color: white;
                                              -fx-border-color: #dde3f0;
                                              -fx-border-radius: 7;
                                              -fx-background-radius: 7;
                                              -fx-font-size: 11;
                                              -fx-padding: 6 8;"/>
                        </VBox>

                        <!-- Adresse * -->
                        <VBox spacing="3">
                            <Label text="Adresse *"
                                   style="-fx-font-size: 10; -fx-font-weight: bold;
                                          -fx-text-fill: #555;"/>
                            <TextField fx:id="fieldAdresse"
                                       promptText="ex: Rue X, Tunis"
                                       style="-fx-background-color: white;
                                              -fx-border-color: #dde3f0;
                                              -fx-border-radius: 7;
                                              -fx-background-radius: 7;
                                              -fx-font-size: 11;
                                              -fx-padding: 6 8;"/>
                        </VBox>

                        <!-- Téléphone * -->
                        <VBox spacing="3">
                            <Label text="Téléphone *"
                                   style="-fx-font-size: 10; -fx-font-weight: bold;
                                          -fx-text-fill: #555;"/>
                            <TextField fx:id="fieldTel"
                                       promptText="ex: +216 71 000 000"
                                       style="-fx-background-color: white;
                                              -fx-border-color: #dde3f0;
                                              -fx-border-radius: 7;
                                              -fx-background-radius: 7;
                                              -fx-font-size: 11;
                                              -fx-padding: 6 8;"/>
                        </VBox>

                        <!-- Ville * -->
                        <VBox spacing="3">
                            <Label text="Ville *"
                                   style="-fx-font-size: 10; -fx-font-weight: bold;
                                          -fx-text-fill: #555;"/>
                            <TextField fx:id="fieldVille"
                                       promptText="ex: Tunis"
                                       style="-fx-background-color: white;
                                              -fx-border-color: #dde3f0;
                                              -fx-border-radius: 7;
                                              -fx-background-radius: 7;
                                              -fx-font-size: 11;
                                              -fx-padding: 6 8;"/>
                        </VBox>

                        <!-- Spécialités -->
                        <VBox spacing="3">
                            <Label text="Spécialités"
                                   style="-fx-font-size: 10; -fx-font-weight: bold;
                                          -fx-text-fill: #555;"/>
                            <TextField fx:id="fieldSpecialites"
                                       promptText="ex: Cardiologie, Pédiatrie"
                                       style="-fx-background-color: white;
                                              -fx-border-color: #dde3f0;
                                              -fx-border-radius: 7;
                                              -fx-background-radius: 7;
                                              -fx-font-size: 11;
                                              -fx-padding: 6 8;"/>
                        </VBox>

                        <!-- ✅ Type — ComboBox -->
                        <VBox spacing="3">
                            <Label text="Type"
                                   style="-fx-font-size: 10; -fx-font-weight: bold;
                                          -fx-text-fill: #555;"/>
                            <ComboBox fx:id="fieldType" maxWidth="Infinity"
                                      promptText="Choisir un type..."
                                      style="-fx-background-color: white;
                                             -fx-border-color: #dde3f0;
                                             -fx-border-radius: 7;
                                             -fx-background-radius: 7;
                                             -fx-font-size: 11;"/>
                        </VBox>

                        <!-- Capacité -->
                        <VBox spacing="3">
                            <Label text="Capacité (lits)"
                                   style="-fx-font-size: 10; -fx-font-weight: bold;
                                          -fx-text-fill: #555;"/>
                            <TextField fx:id="fieldCapacite"
                                       promptText="ex: 200"
                                       style="-fx-background-color: white;
                                              -fx-border-color: #dde3f0;
                                              -fx-border-radius: 7;
                                              -fx-background-radius: 7;
                                              -fx-font-size: 11;
                                              -fx-padding: 6 8;"/>
                        </VBox>

                        <!-- ✅ Localisation + bouton carte -->
                        <VBox spacing="4">
                            <Label text="Localisation"
                                   style="-fx-font-size: 10; -fx-font-weight: bold;
                                          -fx-text-fill: #555;"/>
                            <HBox spacing="6">
                                <TextField fx:id="fieldLatitude"
                                           promptText="Latitude"
                                           HBox.hgrow="ALWAYS"
                                           style="-fx-background-color: white;
                                                  -fx-border-color: #dde3f0;
                                                  -fx-border-radius: 7;
                                                  -fx-background-radius: 7;
                                                  -fx-font-size: 11;
                                                  -fx-padding: 6 8;"/>
                                <TextField fx:id="fieldLongitude"
                                           promptText="Longitude"
                                           HBox.hgrow="ALWAYS"
                                           style="-fx-background-color: white;
                                                  -fx-border-color: #dde3f0;
                                                  -fx-border-radius: 7;
                                                  -fx-background-radius: 7;
                                                  -fx-font-size: 11;
                                                  -fx-padding: 6 8;"/>
                            </HBox>
                            <!-- ✅ Bouton carte -->
                            <Button fx:id="btnCarteLatLon"
                                    text="📍  Choisir sur la carte"
                                    onAction="#ouvrirCarte"
                                    maxWidth="Infinity"
                                    style="-fx-background-color: #f0f4ff;
                                           -fx-text-fill: #3a7bd5;
                                           -fx-background-radius: 7;
                                           -fx-font-size: 11;
                                           -fx-font-weight: bold;
                                           -fx-padding: 7;
                                           -fx-cursor: hand;
                                           -fx-border-color: #3a7bd5;
                                           -fx-border-width: 0.5;
                                           -fx-border-radius: 7;"/>
                        </VBox>

                        <!-- Urgence -->
                        <CheckBox fx:id="checkUrgence"
                                  text="Service urgence disponible"
                                  style="-fx-font-size: 11; -fx-text-fill: #1a2744;"/>

                        <Region prefHeight="4"/>

                        <!-- Boutons CRUD -->
                        <HBox spacing="6">
                            <Button fx:id="btnAjouter" text="＋ Ajouter"
                                    onAction="#ajouter"
                                    HBox.hgrow="ALWAYS" maxWidth="Infinity"
                                    style="-fx-background-color: #1a2744;
                                           -fx-text-fill: white;
                                           -fx-background-radius: 7;
                                           -fx-font-size: 11; -fx-font-weight: bold;
                                           -fx-padding: 8; -fx-cursor: hand;
                                           -fx-border-color: transparent;"/>
                            <Button fx:id="btnModifier" text="✎ Modifier"
                                    onAction="#modifier"
                                    HBox.hgrow="ALWAYS" maxWidth="Infinity"
                                    style="-fx-background-color: #3a7bd5;
                                           -fx-text-fill: white;
                                           -fx-background-radius: 7;
                                           -fx-font-size: 11; -fx-font-weight: bold;
                                           -fx-padding: 8; -fx-cursor: hand;
                                           -fx-border-color: transparent;"/>
                        </HBox>

                        <HBox spacing="6">
                            <Button fx:id="btnSupprimer" text="✕ Supprimer"
                                    onAction="#supprimer"
                                    HBox.hgrow="ALWAYS" maxWidth="Infinity"
                                    style="-fx-background-color: #e53935;
                                           -fx-text-fill: white;
                                           -fx-background-radius: 7;
                                           -fx-font-size: 11; -fx-font-weight: bold;
                                           -fx-padding: 8; -fx-cursor: hand;
                                           -fx-border-color: transparent;"/>
                            <Button fx:id="btnVider" text="↺ Vider"
                                    onAction="#viderFormulaire"
                                    HBox.hgrow="ALWAYS" maxWidth="Infinity"
                                    style="-fx-background-color: white;
                                           -fx-text-fill: #555;
                                           -fx-background-radius: 7;
                                           -fx-font-size: 11; -fx-font-weight: bold;
                                           -fx-padding: 8; -fx-cursor: hand;
                                           -fx-border-color: #dde3f0;
                                           -fx-border-width: 0.5;"/>
                        </HBox>

                        <!-- Message feedback -->
                        <Label fx:id="errorLabel" wrapText="true"
                               style="-fx-font-size: 11; -fx-min-height: 18;"/>

                    </VBox>
                </ScrollPane>

                <!-- ── TABLEAU + FILTRES (droite) ────────────────── -->
                <VBox spacing="10" HBox.hgrow="ALWAYS">

                    <!-- Recherche + Export -->
                    <VBox spacing="8"
                          style="-fx-background-color: white;
                                 -fx-border-color: #dde3f0; -fx-border-width: 0.5;
                                 -fx-border-radius: 10; -fx-background-radius: 10;
                                 -fx-padding: 12;">

                        <HBox spacing="8" alignment="CENTER_LEFT">
                            <Label text="🔍" style="-fx-font-size: 13;"/>
                            <TextField fx:id="searchField"
                                       promptText="Rechercher par nom, ville, spécialité, tél..."
                                       HBox.hgrow="ALWAYS"
                                       style="-fx-background-color: #f5f7fc;
                                              -fx-border-color: #dde3f0;
                                              -fx-border-radius: 8;
                                              -fx-background-radius: 8;
                                              -fx-font-size: 11;
                                              -fx-padding: 7 10;"/>
                            <Button text="⬇  Exporter CSV"
                                    onAction="#exporterCSV"
                                    style="-fx-background-color: #3a7bd5;
                                           -fx-text-fill: white;
                                           -fx-font-size: 10; -fx-font-weight: bold;
                                           -fx-background-radius: 8;
                                           -fx-padding: 8 12;
                                           -fx-cursor: hand;
                                           -fx-border-color: transparent;"/>
                        </HBox>

                        <HBox spacing="8" alignment="CENTER_LEFT">
                            <Label text="Urgence :"
                                   style="-fx-font-size: 10; -fx-text-fill: #888;
                                          -fx-min-width: 55;"/>
                            <ComboBox fx:id="filterUrgence" prefWidth="155"
                                      style="-fx-background-color: #f5f7fc;
                                             -fx-border-color: #dde3f0;
                                             -fx-border-radius: 7;
                                             -fx-background-radius: 7;
                                             -fx-font-size: 11;"/>
                            <Label text="Trier par :"
                                   style="-fx-font-size: 10; -fx-text-fill: #888;
                                          -fx-min-width: 55;"/>
                            <ComboBox fx:id="sortCombo"
                                      HBox.hgrow="ALWAYS" maxWidth="Infinity"
                                      style="-fx-background-color: #f5f7fc;
                                             -fx-border-color: #dde3f0;
                                             -fx-border-radius: 7;
                                             -fx-background-radius: 7;
                                             -fx-font-size: 11;"/>
                        </HBox>
                    </VBox>

                    <!-- Tableau principal -->
                    <TableView fx:id="tableView"
                               VBox.vgrow="ALWAYS" minHeight="400"
                               style="-fx-background-color: white;
                                      -fx-border-color: #dde3f0;
                                      -fx-border-width: 0.5;
                                      -fx-border-radius: 10;
                                      -fx-background-radius: 10;">
                        <columns>
                            <TableColumn fx:id="colId"
                                         text="ID"          prefWidth="45"/>
                            <TableColumn fx:id="colNom"
                                         text="Nom"         prefWidth="150"/>
                            <TableColumn fx:id="colVille"
                                         text="Ville"       prefWidth="95"/>
                            <TableColumn fx:id="colTel"
                                         text="Téléphone"   prefWidth="115"/>
                            <TableColumn fx:id="colType"
                                         text="Type"        prefWidth="90"/>
                            <TableColumn fx:id="colSpec"
                                         text="Spécialités" prefWidth="150"/>
                            <TableColumn fx:id="colCapacite"
                                         text="Capacité"    prefWidth="70"/>
                            <TableColumn fx:id="colUrgence"
                                         text="Urgence"     prefWidth="65"/>
                            <TableColumn fx:id="colNbRdv"
                                         text="RDV"         prefWidth="50"/>
                            <TableColumn fx:id="colRdvWait"
                                         text="Attente"     prefWidth="60"/>
                            <TableColumn fx:id="colAdresse"
                                         text="Adresse"     prefWidth="180"/>
                        </columns>
                        <placeholder>
                            <Label text="Aucun hôpital trouvé"
                                   style="-fx-text-fill: #aaa; -fx-font-size: 13;"/>
                        </placeholder>
                    </TableView>

                </VBox>
            </HBox>

        </VBox>
    </VBox>
</ScrollPane>