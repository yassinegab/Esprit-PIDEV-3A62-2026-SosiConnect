<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<ScrollPane fitToWidth="true"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.example.servicesociaux.frontoffice.controller.controllers.HopitalController"
            style="-fx-background-color: #fdf6f9; -fx-background: #fdf6f9; -fx-border-color: transparent;">

    <VBox spacing="0" style="-fx-background-color: #fdf6f9; -fx-min-height: 620;">

        <!-- ═══ HEADER ═══ -->
        <HBox alignment="CENTER_LEFT" spacing="12"
              style="-fx-background-color: #fff0f5;
                     -fx-border-color: #f8bbd0;
                     -fx-border-width: 0 0 1 0;
                     -fx-padding: 13 22;">
            <Button text="←" onAction="#retourAccueil"
                    style="-fx-background-color: #fce4ec;
                           -fx-text-fill: #ad1457;
                           -fx-background-radius: 50;
                           -fx-font-size: 15; -fx-font-weight: bold;
                           -fx-padding: 5 14;
                           -fx-border-color: #f8bbd0; -fx-border-radius: 50;
                           -fx-cursor: hand;"/>
            <Label text="🏥  Consultation des Hôpitaux"
                   style="-fx-font-size: 15; -fx-font-weight: bold; -fx-text-fill: #ad1457;"/>
        </HBox>

        <!-- ═══ BODY ═══ -->
        <VBox spacing="12" style="-fx-padding: 16 20;">

            <!-- ── STATISTIQUES ── -->
            <Label text="✦  Statistiques globales"
                   style="-fx-font-size: 12; -fx-font-weight: bold; -fx-text-fill: #ad1457;"/>

            <HBox spacing="12">
                <VBox alignment="CENTER" HBox.hgrow="ALWAYS"
                      style="-fx-background-color: #fce4ec; -fx-border-radius: 10;
                             -fx-background-radius: 10; -fx-padding: 12 8;">
                    <Label fx:id="statTotalHopitaux" text="0"
                           style="-fx-font-size: 22; -fx-font-weight: bold; -fx-text-fill: #ad1457;"/>
                    <Label text="Hôpitaux"
                           style="-fx-font-size: 11; -fx-text-fill: #c48b9f;"/>
                </VBox>
                <VBox alignment="CENTER" HBox.hgrow="ALWAYS"
                      style="-fx-background-color: #e8f5e9; -fx-border-radius: 10;
                             -fx-background-radius: 10; -fx-padding: 12 8;">
                    <Label fx:id="statUrgence" text="0"
                           style="-fx-font-size: 22; -fx-font-weight: bold; -fx-text-fill: #388e3c;"/>
                    <Label text="Avec urgence"
                           style="-fx-font-size: 11; -fx-text-fill: #66bb6a;"/>
                </VBox>
                <VBox alignment="CENTER" HBox.hgrow="ALWAYS"
                      style="-fx-background-color: #e3f2fd; -fx-border-radius: 10;
                             -fx-background-radius: 10; -fx-padding: 12 8;">
                    <Label fx:id="statTotalRdv" text="0"
                           style="-fx-font-size: 22; -fx-font-weight: bold; -fx-text-fill: #1565c0;"/>
                    <Label text="Total RDV"
                           style="-fx-font-size: 11; -fx-text-fill: #42a5f5;"/>
                </VBox>
                <VBox alignment="CENTER" HBox.hgrow="ALWAYS"
                      style="-fx-background-color: #fff8e1; -fx-border-radius: 10;
                             -fx-background-radius: 10; -fx-padding: 12 8;">
                    <Label fx:id="statEnAttente" text="0"
                           style="-fx-font-size: 22; -fx-font-weight: bold; -fx-text-fill: #f57f17;"/>
                    <Label text="En attente"
                           style="-fx-font-size: 11; -fx-text-fill: #ffb300;"/>
                </VBox>
            </HBox>

            <!-- ── FILTRES + RECHERCHE ── -->
            <Label text="✦  Liste des hôpitaux"
                   style="-fx-font-size: 12; -fx-font-weight: bold; -fx-text-fill: #ad1457;"/>

            <VBox spacing="7"
                  style="-fx-background-color: #fff0f5;
                         -fx-border-color: #f8bbd0;
                         -fx-border-radius: 10; -fx-background-radius: 10;
                         -fx-padding: 12;">

                <HBox spacing="8" alignment="CENTER_LEFT">
                    <Label text="🔍" style="-fx-font-size: 13;"/>
                    <TextField fx:id="searchField"
                               promptText="Rechercher par nom, adresse, spécialité, téléphone..."
                               HBox.hgrow="ALWAYS"
                               style="-fx-background-color: white;
                                      -fx-border-color: #f8bbd0; -fx-border-radius: 8;
                                      -fx-background-radius: 8; -fx-font-size: 12;
                                      -fx-padding: 7 10;"/>
                    <Button text="⬇  Exporter CSV" onAction="#exporterCSV"
                            style="-fx-background-color: #f48fb1; -fx-text-fill: white;
                                   -fx-font-size: 11; -fx-font-weight: bold;
                                   -fx-background-radius: 8; -fx-padding: 8 14;
                                   -fx-cursor: hand; -fx-border-color: transparent;"/>
                    <Button text="📄 Exporter PDF" onAction="#exporterPDF"
                            style="-fx-background-color: #7b1fa2; -fx-text-fill: white;
               -fx-font-size: 11; -fx-font-weight: bold;
               -fx-background-radius: 8; -fx-padding: 8 14;
               -fx-cursor: hand; -fx-border-color: transparent;"/>
                    <Button text="🗺 Voir sur carte" onAction="#ouvrirCarte"
                            style="-fx-background-color: #1565c0; -fx-text-fill: white;
               -fx-font-size: 11; -fx-font-weight: bold;
               -fx-background-radius: 8; -fx-padding: 8 14;
               -fx-cursor: hand;"/>

                </HBox>


                <HBox spacing="8" alignment="CENTER_LEFT">
                    <Label text="Urgence :"
                           style="-fx-font-size: 11; -fx-text-fill: #c48b9f; -fx-min-width: 58;"/>
                    <ComboBox fx:id="filterUrgence" prefWidth="160"
                              style="-fx-background-color: white;
                                     -fx-border-color: #f8bbd0; -fx-border-radius: 7;
                                     -fx-background-radius: 7; -fx-font-size: 11;"/>

                    <Label text="Trier par :"
                           style="-fx-font-size: 11; -fx-text-fill: #c48b9f; -fx-min-width: 58;"/>
                    <ComboBox fx:id="sortCombo" HBox.hgrow="ALWAYS" maxWidth="Infinity"
                              style="-fx-background-color: white;
                                     -fx-border-color: #f8bbd0; -fx-border-radius: 7;
                                     -fx-background-radius: 7; -fx-font-size: 11;"/>
                </HBox>
            </VBox>

            <!-- ── TABLEAU (pleine largeur) ── -->
            <TableView fx:id="tableView" VBox.vgrow="ALWAYS" minHeight="380"
                       style="-fx-background-color: white;
                              -fx-border-color: #e0e0e0;
                              -fx-border-radius: 10; -fx-background-radius: 10;">
                <columns>
                    <TableColumn fx:id="colId"      text="ID"           prefWidth="50"/>
                    <TableColumn fx:id="colNom"     text="Nom"          prefWidth="200"/>
                    <TableColumn fx:id="colAdresse" text="Adresse"      prefWidth="200"/>
                    <TableColumn fx:id="colTel"     text="Téléphone"    prefWidth="130"/>
                    <TableColumn fx:id="colSpec"    text="Spécialités"  prefWidth="180"/>
                    <TableColumn fx:id="colUrgence" text="Urgence"      prefWidth="80"/>
                    <TableColumn fx:id="colNbRdv"   text="Nb RDV"       prefWidth="75"/>
                    <TableColumn fx:id="colRdvWait" text="En attente"   prefWidth="85"/>
                </columns>
                <placeholder>
                    <Label text="Aucun hôpital disponible 🌸"
                           style="-fx-text-fill: #f48fb1; -fx-font-size: 13;"/>
                </placeholder>
            </TableView>

            <Label fx:id="errorLabel" wrapText="true"
                   style="-fx-font-size: 11; -fx-min-height: 16;"/>

        </VBox>
    </VBox>
</ScrollPane>
