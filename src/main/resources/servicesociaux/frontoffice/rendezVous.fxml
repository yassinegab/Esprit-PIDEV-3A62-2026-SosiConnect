<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<ScrollPane fitToWidth="true"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.example.servicesociaux.frontoffice.controller.controllers.RendezVousController"
            style="-fx-background-color: #fdf6f9; -fx-background: #fdf6f9; -fx-border-color: transparent;">

    <VBox spacing="0" style="-fx-background-color: #fdf6f9; -fx-min-height: 620;">

        <!-- ═══ HEADER ═══ -->
        <HBox alignment="CENTER_LEFT" spacing="12"
              style="-fx-background-color: #fff0f5;
                     -fx-border-color: #f8bbd0;
                     -fx-border-width: 0 0 1 0;
                     -fx-padding: 13 22;">
            <Button text="←" onAction="#retourAccueil"
                    style="-fx-background-color: #fce4ec;
                           -fx-text-fill: #ad1457;
                           -fx-background-radius: 50;
                           -fx-font-size: 15; -fx-font-weight: bold;
                           -fx-padding: 5 14;
                           -fx-border-color: #f8bbd0; -fx-border-radius: 50;
                           -fx-cursor: hand;"/>
            <Label text="📅  Gestion des Rendez-Vous"
                   style="-fx-font-size: 15; -fx-font-weight: bold; -fx-text-fill: #ad1457;"/>
        </HBox>

        <!-- ═══ BODY ═══ -->
        <HBox spacing="0" VBox.vgrow="ALWAYS" minHeight="560">

            <!-- ── PANNEAU FORMULAIRE (gauche) ── -->
            <ScrollPane fitToWidth="true" hbarPolicy="NEVER"
                        style="-fx-background-color: #fff8fb; -fx-background: #fff8fb;
                               -fx-border-color: #f8bbd0; -fx-border-width: 0 1 0 0;
                               -fx-min-width: 290; -fx-max-width: 290; -fx-pref-width: 290;">
                <VBox spacing="8"
                      style="-fx-padding: 18 16;
                             -fx-background-color: #fff8fb;
                             -fx-min-width: 258;">

                    <Label text="✦  Nouveau rendez-vous"
                           style="-fx-font-size: 12; -fx-font-weight: bold;
                                  -fx-text-fill: #ad1457; -fx-padding: 0 0 6 0;"/>

                    <Label text="Hôpital" style="-fx-font-size: 10; -fx-text-fill: #c48b9f;"/>
                    <ComboBox fx:id="hopitalCombo" maxWidth="Infinity"
                              promptText="Sélectionner un hôpital"
                              style="-fx-background-color: white;
                                     -fx-border-color: #f8bbd0; -fx-border-radius: 8;
                                     -fx-background-radius: 8; -fx-font-size: 12;"/>

                    <Label text="Type de consultation"
                           style="-fx-font-size: 10; -fx-text-fill: #c48b9f;"/>
                    <ComboBox fx:id="typeConsultation" maxWidth="Infinity"
                              promptText="Choisir le type"
                              style="-fx-background-color: white;
                                     -fx-border-color: #f8bbd0; -fx-border-radius: 8;
                                     -fx-background-radius: 8; -fx-font-size: 12;"/>

                    <Label text="Statut" style="-fx-font-size: 10; -fx-text-fill: #c48b9f;"/>
                    <ComboBox fx:id="statut" maxWidth="Infinity"
                              promptText="Choisir le statut"
                              style="-fx-background-color: white;
                                     -fx-border-color: #f8bbd0; -fx-border-radius: 8;
                                     -fx-background-radius: 8; -fx-font-size: 12;"/>

                    <Label text="Date et heure"
                           style="-fx-font-size: 10; -fx-text-fill: #c48b9f;"/>
                    <DatePicker fx:id="datePicker" maxWidth="Infinity"
                                promptText="Choisir une date"
                                style="-fx-background-color: white;
                                       -fx-border-color: #f8bbd0; -fx-border-radius: 8;
                                       -fx-background-radius: 8; -fx-font-size: 12;"/>

                    <HBox spacing="8">
                        <ComboBox fx:id="heureCombo" promptText="HH"
                                  HBox.hgrow="ALWAYS" maxWidth="Infinity"
                                  style="-fx-background-color: white;
                                         -fx-border-color: #f8bbd0; -fx-border-radius: 8;
                                         -fx-background-radius: 8; -fx-font-size: 12;"/>
                        <Label text="h"
                               style="-fx-text-fill: #c48b9f; -fx-font-size: 13;
                                      -fx-padding: 6 0;"/>
                        <ComboBox fx:id="minuteCombo" promptText="MM"
                                  HBox.hgrow="ALWAYS" maxWidth="Infinity"
                                  style="-fx-background-color: white;
                                         -fx-border-color: #f8bbd0; -fx-border-radius: 8;
                                         -fx-background-radius: 8; -fx-font-size: 12;"/>
                        <Label text="min"
                               style="-fx-text-fill: #c48b9f; -fx-font-size: 11;
                                      -fx-padding: 6 0;"/>
                    </HBox>

                    <Label text="Notes" style="-fx-font-size: 10; -fx-text-fill: #c48b9f;"/>
                    <TextArea fx:id="notesField" prefRowCount="3"
                              promptText="Remarques..."
                              style="-fx-background-color: white;
                                     -fx-border-color: #f8bbd0; -fx-border-radius: 8;
                                     -fx-background-radius: 8; -fx-font-size: 12; -fx-padding: 7;"/>

                    <Label fx:id="errorLabel" wrapText="true"
                           style="-fx-font-size: 11; -fx-min-height: 16;"/>

                    <VBox spacing="7" style="-fx-padding: 4 0 0 0;">
                        <Button text="✚   Ajouter" onAction="#ajouter" maxWidth="Infinity"
                                style="-fx-background-color: #f48fb1; -fx-text-fill: white;
                                       -fx-font-size: 12; -fx-font-weight: bold;
                                       -fx-background-radius: 10; -fx-padding: 10;
                                       -fx-cursor: hand;"/>
                        <Button text="✎   Modifier" onAction="#modifier" maxWidth="Infinity"
                                style="-fx-background-color: #fce4ec; -fx-text-fill: #880e4f;
                                       -fx-font-size: 12; -fx-font-weight: bold;
                                       -fx-background-radius: 10;
                                       -fx-border-color: #f8bbd0; -fx-border-radius: 10;
                                       -fx-padding: 10; -fx-cursor: hand;"/>
                        <Button text="✖   Supprimer" onAction="#supprimer" maxWidth="Infinity"
                                style="-fx-background-color: white; -fx-text-fill: #c62828;
                                       -fx-font-size: 12; -fx-font-weight: bold;
                                       -fx-background-radius: 10;
                                       -fx-border-color: #f8bbd0; -fx-border-radius: 10;
                                       -fx-padding: 10; -fx-cursor: hand;"/>
                        <Button fx:id="annulerBtn" text="↺   Annuler sélection"
                                onAction="#annuler"
                                maxWidth="Infinity" visible="false" managed="false"
                                style="-fx-background-color: #f5f5f5; -fx-text-fill: #999;
                                       -fx-font-size: 12; -fx-background-radius: 10;
                                       -fx-border-color: #e0e0e0; -fx-border-radius: 10;
                                       -fx-padding: 10; -fx-cursor: hand;"/>
                    </VBox>
                </VBox>
            </ScrollPane>

            <!-- ── PANNEAU DROIT (stats + filtres + tableau) ── -->
            <VBox VBox.vgrow="ALWAYS" HBox.hgrow="ALWAYS"
                  spacing="10" style="-fx-padding: 16 16; -fx-min-width: 400;">

                <!-- ── STATISTIQUES GLOBALES ── -->
                <Label text="✦  Statistiques globales"
                       style="-fx-font-size: 12; -fx-font-weight: bold; -fx-text-fill: #ad1457;"/>

                <HBox spacing="10">
                    <VBox alignment="CENTER" HBox.hgrow="ALWAYS"
                          style="-fx-background-color: #fce4ec; -fx-border-radius: 10;
                                 -fx-background-radius: 10; -fx-padding: 10 6;">
                        <Label fx:id="statTotal" text="0"
                               style="-fx-font-size: 20; -fx-font-weight: bold; -fx-text-fill: #ad1457;"/>
                        <Label text="Total RDV"
                               style="-fx-font-size: 10; -fx-text-fill: #c48b9f;"/>
                    </VBox>
                    <VBox alignment="CENTER" HBox.hgrow="ALWAYS"
                          style="-fx-background-color: #fff8e1; -fx-border-radius: 10;
                                 -fx-background-radius: 10; -fx-padding: 10 6;">
                        <Label fx:id="statEnAttente" text="0"
                               style="-fx-font-size: 20; -fx-font-weight: bold; -fx-text-fill: #f57f17;"/>
                        <Label text="En attente"
                               style="-fx-font-size: 10; -fx-text-fill: #ffb300;"/>
                    </VBox>
                    <VBox alignment="CENTER" HBox.hgrow="ALWAYS"
                          style="-fx-background-color: #e8f5e9; -fx-border-radius: 10;
                                 -fx-background-radius: 10; -fx-padding: 10 6;">
                        <Label fx:id="statConfirme" text="0"
                               style="-fx-font-size: 20; -fx-font-weight: bold; -fx-text-fill: #388e3c;"/>
                        <Label text="Confirmés"
                               style="-fx-font-size: 10; -fx-text-fill: #66bb6a;"/>
                    </VBox>
                    <VBox alignment="CENTER" HBox.hgrow="ALWAYS"
                          style="-fx-background-color: #e3f2fd; -fx-border-radius: 10;
                                 -fx-background-radius: 10; -fx-padding: 10 6;">
                        <Label fx:id="statTermine" text="0"
                               style="-fx-font-size: 20; -fx-font-weight: bold; -fx-text-fill: #1565c0;"/>
                        <Label text="Terminés"
                               style="-fx-font-size: 10; -fx-text-fill: #42a5f5;"/>
                    </VBox>
                    <VBox alignment="CENTER" HBox.hgrow="ALWAYS"
                          style="-fx-background-color: #fbe9e7; -fx-border-radius: 10;
                                 -fx-background-radius: 10; -fx-padding: 10 6;">
                        <Label fx:id="statAnnule" text="0"
                               style="-fx-font-size: 20; -fx-font-weight: bold; -fx-text-fill: #bf360c;"/>
                        <Label text="Annulés"
                               style="-fx-font-size: 10; -fx-text-fill: #ff7043;"/>
                    </VBox>
                </HBox>

                <!-- ── TITRE LISTE ── -->
                <Label text="✦  Liste des rendez-vous"
                       style="-fx-font-size: 12; -fx-font-weight: bold; -fx-text-fill: #ad1457;"/>

                <!-- ── FILTRES + EXPORT ── -->
                <VBox spacing="7"
                      style="-fx-background-color: #fff0f5;
                             -fx-border-color: #f8bbd0;
                             -fx-border-radius: 10; -fx-background-radius: 10;
                             -fx-padding: 12;">

                    <HBox spacing="8" alignment="CENTER_LEFT">
                        <Label text="🔍" style="-fx-font-size: 13;"/>
                        <TextField fx:id="searchField"
                                   promptText="Rechercher..."
                                   HBox.hgrow="ALWAYS"
                                   style="-fx-background-color: white;
                                          -fx-border-color: #f8bbd0; -fx-border-radius: 8;
                                          -fx-background-radius: 8; -fx-font-size: 12;
                                          -fx-padding: 7 10;"/>
                        <Button text="⬇  Exporter CSV" onAction="#exporterCSV"
                                style="-fx-background-color: #f48fb1; -fx-text-fill: white;
                                       -fx-font-size: 11; -fx-font-weight: bold;
                                       -fx-background-radius: 8; -fx-padding: 8 14;
                                       -fx-cursor: hand; -fx-border-color: transparent;"/>
                    </HBox>

                    <HBox spacing="8" alignment="CENTER_LEFT">
                        <Label text="Statut :"
                               style="-fx-font-size: 11; -fx-text-fill: #c48b9f; -fx-min-width: 45;"/>
                        <ComboBox fx:id="filterStatut" prefWidth="120"
                                  style="-fx-background-color: white;
                                         -fx-border-color: #f8bbd0; -fx-border-radius: 7;
                                         -fx-background-radius: 7; -fx-font-size: 11;"/>
                        <Label text="Type :"
                               style="-fx-font-size: 11; -fx-text-fill: #c48b9f; -fx-min-width: 38;"/>
                        <ComboBox fx:id="filterType" prefWidth="130"
                                  style="-fx-background-color: white;
                                         -fx-border-color: #f8bbd0; -fx-border-radius: 7;
                                         -fx-background-radius: 7; -fx-font-size: 11;"/>
                        <Label text="Hôpital :"
                               style="-fx-font-size: 11; -fx-text-fill: #c48b9f; -fx-min-width: 50;"/>
                        <ComboBox fx:id="filterHopital"
                                  HBox.hgrow="ALWAYS" maxWidth="Infinity"
                                  style="-fx-background-color: white;
                                         -fx-border-color: #f8bbd0; -fx-border-radius: 7;
                                         -fx-background-radius: 7; -fx-font-size: 11;"/>
                    </HBox>
                </VBox>

                <!-- ── TABLEAU ── -->
                <TableView fx:id="tableView" VBox.vgrow="ALWAYS" minHeight="300"
                           style="-fx-background-color: white;
                                  -fx-border-color: #e0e0e0;
                                  -fx-border-radius: 10; -fx-background-radius: 10;">
                    <columns>
                        <TableColumn fx:id="colId"      text="ID"               prefWidth="45"/>
                        <TableColumn fx:id="colPatient"  text="Patient"          prefWidth="65"/>
                        <TableColumn fx:id="colHopital"  text="Hôpital"          prefWidth="150"/>
                        <TableColumn fx:id="colType"     text="Type"             prefWidth="125"/>
                        <TableColumn fx:id="colStatut"   text="Statut"           prefWidth="100"/>
                        <TableColumn fx:id="colDate"     text="Date &amp; Heure" prefWidth="145"/>
                        <TableColumn fx:id="colNotes"    text="Notes"            prefWidth="150"/>
                    </columns>
                    <placeholder>
                        <Label text="Aucun rendez-vous trouvé 🌸"
                               style="-fx-text-fill: #f48fb1; -fx-font-size: 13;"/>
                    </placeholder>
                </TableView>

            </VBox>
        </HBox>
    </VBox>
</ScrollPane>
