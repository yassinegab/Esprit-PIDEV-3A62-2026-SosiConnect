<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.chart.*?>

<VBox spacing="20.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.wellbeing.backoffice.controller.WellbeingAdminController">
   <children>
      <HBox alignment="CENTER_LEFT" spacing="20.0">
         <children>
            <Label style="-fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: #1e293b;" text="Bien-être Mental" />
            <Region HBox.hgrow="ALWAYS" />
            <Button style="-fx-background-color: #6366f1; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10 20; -fx-background-radius: 5;" text="+ Nouveau Rapport" />
         </children>
      </HBox>
      
      <HBox spacing="15.0">
         <children>
            <VBox prefWidth="240.0" style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 20; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.02), 5, 0, 0, 0);">
               <children>
                  <Label style="-fx-text-fill: #94a3b8; -fx-font-size: 12;" text="Total Évaluations" />
                  <Label fx:id="lblTotalUsers" style="-fx-font-size: 28; -fx-font-weight: bold; -fx-text-fill: #1e293b;" text="1,284" />
                  <Label style="-fx-text-fill: #10b981; -fx-font-size: 11;" text="↑ 12% vs mois dernier" />
               </children>
            </VBox>
            <VBox prefWidth="240.0" style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 20; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.02), 5, 0, 0, 0);">
               <children>
                  <Label style="-fx-text-fill: #94a3b8; -fx-font-size: 12;" text="Stress Critique" />
                  <Label fx:id="lblHighAnxiety" style="-fx-font-size: 28; -fx-font-weight: bold; -fx-text-fill: #ef4444;" text="42" />
                  <Label style="-fx-text-fill: #ef4444; -fx-font-size: 11;" text="↑ 5% Action requise" />
               </children>
            </VBox>
            <VBox prefWidth="240.0" style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 20; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.02), 5, 0, 0, 0);">
               <children>
                  <Label style="-fx-text-fill: #94a3b8; -fx-font-size: 12;" text="Moyenne Bien-être" />
                  <Label fx:id="lblAvgSleep" style="-fx-font-size: 28; -fx-font-weight: bold; -fx-text-fill: #6366f1;" text="3.8/5" />
                  <Label style="-fx-text-fill: #6366f1; -fx-font-size: 11;" text="Stable" />
               </children>
            </VBox>
            <VBox prefWidth="240.0" style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 20; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.02), 5, 0, 0, 0);">
               <children>
                  <Label style="-fx-text-fill: #94a3b8; -fx-font-size: 12;" text="Analyses IA" />
                  <Label fx:id="lblAvgHeartbeat" style="-fx-font-size: 28; -fx-font-weight: bold; -fx-text-fill: #f59e0b;" text="98%" />
                  <Label style="-fx-text-fill: #94a3b8; -fx-font-size: 11;" text="Précision modèle" />
               </children>
            </VBox>
         </children>
      </HBox>
      
      <HBox spacing="20.0" VBox.vgrow="ALWAYS">
         <children>
            <!-- Charts Section -->
            <VBox spacing="15.0" HBox.hgrow="ALWAYS" maxWidth="800">
               <children>
                  <!-- Line Chart for Trends -->
                  <VBox style="-fx-background-color: white; -fx-background-radius: 15; -fx-padding: 20; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 10, 0, 0, 5);">
                     <padding>
                        <Insets bottom="10.0" />
                     </padding>
                     <children>
                        <Label style="-fx-font-weight: bold; -fx-font-size: 16; -fx-text-fill: #1e293b;" text="Tendance du Bien-être Global" />
                        <LineChart fx:id="chartTrend" createSymbols="true" prefHeight="250.0">
                           <xAxis>
                              <CategoryAxis side="BOTTOM" />
                           </xAxis>
                           <yAxis>
                              <NumberAxis side="LEFT" upperBound="5.0" lowerBound="1.0" tickUnit="1.0" autoRanging="false" />
                           </yAxis>
                        </LineChart>
                     </children>
                  </VBox>
                  
                  <!-- Distribution and Top Risks Row -->
                  <HBox spacing="15.0" VBox.vgrow="ALWAYS">
                     <children>
                        <VBox style="-fx-background-color: white; -fx-background-radius: 15; -fx-padding: 20; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 10, 0, 0, 5);" HBox.hgrow="ALWAYS">
                           <children>
                              <Label style="-fx-font-weight: bold; -fx-font-size: 14; -fx-text-fill: #1e293b;" text="Répartition du Stress" />
                              <PieChart fx:id="chartDistribution" prefHeight="200.0" />
                           </children>
                        </VBox>
                        <VBox prefWidth="300.0" style="-fx-background-color: #fef2f2; -fx-background-radius: 15; -fx-padding: 20; -fx-border-color: #fee2e2; -fx-border-radius: 15;">
                           <children>
                              <Label style="-fx-font-weight: bold; -fx-font-size: 14; -fx-text-fill: #991b1b;" text="Alertes Critiques (24h)" />
                              <Label fx:id="lblCriticalActive" style="-fx-font-size: 32; -fx-font-weight: bold; -fx-text-fill: #b91c1c;" text="0" />
                              <Label wrapText="true" style="-fx-text-fill: #7f1d1d; -fx-font-size: 11;" text="Utilisateurs rapportant des niveaux d'anxiété extrêmes nécessitant une attention immédiate." />
                              <Region VBox.vgrow="ALWAYS" />
                              <Button onAction="#handleViewCriticalAlerts" style="-fx-background-color: #b91c1c; -fx-text-fill: white; -fx-background-radius: 8;" text="Voir les Alertes" maxWidth="Infinity" />
                           </children>
                        </VBox>
                     </children>
                  </HBox>
               </children>
            </VBox>
            
            <!-- Audit Table Section -->
            <VBox style="-fx-background-color: white; -fx-background-radius: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 10, 0, 0, 5);" HBox.hgrow="ALWAYS">
               <children>
                  <HBox alignment="CENTER_LEFT" spacing="15.0" style="-fx-padding: 20;">
                     <children>
                        <Label style="-fx-font-weight: bold; -fx-font-size: 16;" text="Audit des Évaluations" />
                        <Region HBox.hgrow="ALWAYS" />
                        <TextField promptText="Chercher utilisateur..." style="-fx-background-color: #f1f5f9; -fx-background-radius: 8; -fx-padding: 8 15;" />
                     </children>
                  </HBox>
                  <TableView fx:id="tblData" style="-fx-background-color: transparent; -fx-border-width: 0;" VBox.vgrow="ALWAYS">
                    <columns>
                      <TableColumn fx:id="colId" prefWidth="50.0" text="ID" />
                      <TableColumn fx:id="colWork" prefWidth="120.0" text="Niveau Stress" />
                      <TableColumn fx:id="colAnxiety" prefWidth="120.0" text="Anxiété" />
                      <TableColumn fx:id="colCreated" prefWidth="150.0" text="Date Session" />
                      <TableColumn fx:id="colActions" prefWidth="100.0" text="Audit" />
                    </columns>
                  </TableView>
               </children>
            </VBox>
         </children>
      </HBox>
   </children>
</VBox>
