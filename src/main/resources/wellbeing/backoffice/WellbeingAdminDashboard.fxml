<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Circle?>

<BorderPane prefHeight="800.0" prefWidth="1200.0" style="-fx-background-color: #f1f5f9;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.wellbeing.backoffice.controller.WellbeingAdminController">
   <left>
      <VBox prefWidth="240.0" spacing="10.0" style="-fx-background-color: white; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 10, 0, 0, 0);" BorderPane.alignment="CENTER">
         <children>
            <HBox alignment="CENTER_LEFT" spacing="10.0">
               <children>
                  <Circle fill="#6366f1" radius="15.0" />
                  <VBox>
                     <children>
                        <Label style="-fx-font-weight: bold; -fx-font-size: 16;" text="Sosi" />
                        <Label style="-fx-font-size: 10; -fx-text-fill: #94a3b8;" text="Admin Panel" />
                     </children>
                  </VBox>
               </children>
               <padding>
                  <Insets bottom="20.0" left="20.0" top="20.0" />
               </padding>
            </HBox>
            
            <VBox spacing="5.0">
               <children>
                  <Button alignment="BASELINE_LEFT" prefMaxWidth="Infinity" style="-fx-background-color: transparent; -fx-text-fill: #475569; -fx-padding: 10 20;" text="📊 Dashboard" />
                  <Button alignment="BASELINE_LEFT" prefMaxWidth="Infinity" style="-fx-background-color: transparent; -fx-text-fill: #475569; -fx-padding: 10 20;" text="👥 Gestion Utilisateurs" />
                  <Button alignment="BASELINE_LEFT" prefMaxWidth="Infinity" style="-fx-background-color: #f1f5f9; -fx-text-fill: #6366f1; -fx-font-weight: bold; -fx-padding: 10 20;" text="🧠 Gestion Bien-être" />
                  <Button alignment="BASELINE_LEFT" prefMaxWidth="Infinity" style="-fx-background-color: transparent; -fx-text-fill: #475569; -fx-padding: 10 20;" text="📈 Analytiques" />
                  <Button alignment="BASELINE_LEFT" prefMaxWidth="Infinity" style="-fx-background-color: transparent; -fx-text-fill: #475569; -fx-padding: 10 20;" text="⚙️ Paramètres" />
               </children>
            </VBox>
         </children>
      </VBox>
   </left>
   <center>
      <VBox spacing="20.0" BorderPane.alignment="CENTER">
         <children>
            <HBox alignment="CENTER_LEFT" spacing="20.0">
               <children>
                  <Label style="-fx-font-size: 20; -fx-font-weight: bold;" text="Admin Dashboard - Module Template" />
               </children>
            </HBox>
            
            <HBox spacing="15.0">
               <children>
                  <VBox prefWidth="240.0" style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 20;">
                     <children>
                        <Label style="-fx-text-fill: #94a3b8; -fx-font-size: 12;" text="Statistique 1" />
                        <Label fx:id="lblTotalUsers" style="-fx-font-size: 24; -fx-font-weight: bold;" text="0" />
                     </children>
                  </VBox>
                  <VBox prefWidth="240.0" style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 20;">
                     <children>
                        <Label style="-fx-text-fill: #94a3b8; -fx-font-size: 12;" text="Statistique 2" />
                        <Label fx:id="lblStat2" style="-fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: #ef4444;" text="0" />
                     </children>
                  </VBox>
                  <VBox prefWidth="240.0" style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 20;">
                     <children>
                        <Label style="-fx-text-fill: #94a3b8; -fx-font-size: 12;" text="Statistique 3" />
                        <Label fx:id="lblStat3" style="-fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: #6366f1;" text="0" />
                     </children>
                  </VBox>
                  <VBox prefWidth="240.0" style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 20;">
                     <children>
                        <Label style="-fx-text-fill: #94a3b8; -fx-font-size: 12;" text="Statistique 4" />
                        <Label fx:id="lblStat4" style="-fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: #f59e0b;" text="0" />
                     </children>
                  </VBox>
               </children>
            </HBox>
            
            <VBox style="-fx-background-color: white; -fx-background-radius: 10;" VBox.vgrow="ALWAYS">
               <children>
                  <HBox alignment="CENTER_LEFT" spacing="15.0" style="-fx-padding: 15;">
                     <children>
                        <TextField promptText="Search..." style="-fx-background-color: #f1f5f9; -fx-background-radius: 5;" />
                        <ComboBox prefWidth="150.0" promptText="Filter By" style="-fx-background-color: #f1f5f9;" />
                        <ComboBox prefWidth="150.0" promptText="Sort By" style="-fx-background-color: #f1f5f9;" />
                        <Button onAction="#handleApplyFilter" style="-fx-background-color: #6366f1; -fx-text-fill: white; -fx-font-weight: bold;" text="Apply" />
                     </children>
                  </HBox>
                  <TableView fx:id="tblData" style="-fx-background-color: transparent;" VBox.vgrow="ALWAYS">
                    <columns>
                      <TableColumn fx:id="colId" prefWidth="50.0" text="Id" />
                      <TableColumn fx:id="colField1" prefWidth="150.0" text="Champ 1" />
                      <TableColumn fx:id="colField2" prefWidth="150.0" text="Champ 2" />
                      <TableColumn fx:id="colDate" prefWidth="150.0" text="Date Création" />
                      <TableColumn fx:id="colActions" prefWidth="100.0" text="Actions" />
                    </columns>
                  </TableView>
               </children>
            </VBox>
         </children>
         <padding>
            <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
         </padding>
      </VBox>
   </center>
</BorderPane>
