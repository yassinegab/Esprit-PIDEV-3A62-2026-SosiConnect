<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Circle?>

<VBox prefWidth="500.0" prefHeight="650.0" spacing="0" style="-fx-background-color: white; -fx-background-radius: 20; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 30, 0, 0, 15);" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.wellbeing.backoffice.controller.WellbeingDetailPopupController">
   <children>
      <!-- Header -->
      <HBox alignment="CENTER_LEFT" spacing="15.0" style="-fx-background-color: linear-gradient(to right, #1e293b, #334155); -fx-padding: 25; -fx-background-radius: 20 20 0 0;">
         <children>
            <VBox HBox.hgrow="ALWAYS">
               <children>
                  <Label style="-fx-text-fill: white; -fx-font-size: 18; -fx-font-weight: bold;" text="Rapport d'Évaluation Détaillé" />
                  <Label fx:id="lblSessionDate" style="-fx-text-fill: #94a3b8; -fx-font-size: 12;" text="Session du 12 Avril 2024" />
               </children>
            </VBox>
            <Button onAction="#handleClose" style="-fx-background-color: rgba(255,255,255,0.1); -fx-text-fill: white; -fx-background-radius: 50; -fx-min-width: 35; -fx-min-height: 35;" text="✕" />
         </children>
      </HBox>

      <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-color: transparent;" VBox.vgrow="ALWAYS">
         <content>
            <VBox spacing="20.0" style="-fx-padding: 30;">
               <children>
                  <!-- Summary Card -->
                  <VBox style="-fx-background-color: #f8fafc; -fx-background-radius: 12; -fx-padding: 20; -fx-border-color: #e2e8f0; -fx-border-radius: 12;">
                     <children>
                        <Label style="-fx-font-weight: bold; -fx-text-fill: #64748b; -fx-font-size: 11; -fx-text-transform: uppercase;" text="Score de Stress Global" />
                        <HBox alignment="BOTTOM_LEFT" spacing="10.0">
                           <children>
                              <Label fx:id="lblStressScore" style="-fx-font-size: 48; -fx-font-weight: 900; -fx-text-fill: #1e293b;" text="3.5" />
                              <Label style="-fx-text-fill: #94a3b8; -fx-font-size: 18; -fx-padding: 0 0 8 0;" text="/ 5.0" />
                              <Region HBox.hgrow="ALWAYS" />
                              <Label fx:id="lblStressStatus" style="-fx-background-color: #fef3c7; -fx-text-fill: #92400e; -fx-padding: 5 12; -fx-background-radius: 20; -fx-font-size: 12; -fx-font-weight: bold;" text="Modéré" />
                           </children>
                        </HBox>
                     </children>
                  </VBox>

                  <!-- Metrics Grid -->
                  <Label style="-fx-font-weight: bold; -fx-font-size: 14;" text="Anatomie de la Session" />
                  <FlowPane hgap="15.0" vgap="15.0">
                     <children>
                        <VBox prefWidth="135.0" style="-fx-background-color: white; -fx-border-color: #f1f5f9; -fx-border-radius: 10; -fx-padding: 15;">
                           <children>
                              <Label style="-fx-text-fill: #94a3b8; -fx-font-size: 10;" text="ANXIÉTÉ" />
                              <Label fx:id="valAnxiety" style="-fx-font-size: 18; -fx-font-weight: bold;" text="4/5" />
                           </children>
                        </VBox>
                        <VBox prefWidth="135.0" style="-fx-background-color: white; -fx-border-color: #f1f5f9; -fx-border-radius: 10; -fx-padding: 15;">
                           <children>
                              <Label style="-fx-text-fill: #94a3b8; -fx-font-size: 10;" text="SOMMEIL" />
                              <Label fx:id="valSleep" style="-fx-font-size: 18; -fx-font-weight: bold;" text="2/5" />
                           </children>
                        </VBox>
                        <VBox prefWidth="135.0" style="-fx-background-color: white; -fx-border-color: #f1f5f9; -fx-border-radius: 10; -fx-padding: 15;">
                           <children>
                              <Label style="-fx-text-fill: #94a3b8; -fx-font-size: 10;" text="IRRITABILITÉ" />
                              <Label fx:id="valIrritability" style="-fx-font-size: 18; -fx-font-weight: bold;" text="3/5" />
                           </children>
                        </VBox>
                        <VBox prefWidth="135.0" style="-fx-background-color: white; -fx-border-color: #f1f5f9; -fx-border-radius: 10; -fx-padding: 15;">
                           <children>
                              <Label style="-fx-text-fill: #94a3b8; -fx-font-size: 10;" text="CONFIDENCE CP" />
                              <Label fx:id="valConfidence" style="-fx-font-size: 18; -fx-font-weight: bold;" text="2/5" />
                           </children>
                        </VBox>
                        <VBox prefWidth="135.0" style="-fx-background-color: white; -fx-border-color: #f1f5f9; -fx-border-radius: 10; -fx-padding: 15;">
                           <children>
                              <Label style="-fx-text-fill: #94a3b8; -fx-font-size: 10;" text="MAUX DE TÊTE" />
                              <Label fx:id="valHeadache" style="-fx-font-size: 18; -fx-font-weight: bold;" text="1/5" />
                           </children>
                        </VBox>
                        <VBox prefWidth="135.0" style="-fx-background-color: white; -fx-border-color: #f1f5f9; -fx-border-radius: 10; -fx-padding: 15;">
                           <children>
                              <Label style="-fx-text-fill: #94a3b8; -fx-font-size: 10;" text="PALPITATIONS" />
                              <Label fx:id="valHeart" style="-fx-font-size: 18; -fx-font-weight: bold;" text="1/5" />
                           </children>
                        </VBox>
                     </children>
                  </FlowPane>

                  <!-- AI Prediction Section -->
                  <VBox spacing="10.0" style="-fx-background-color: #eff6ff; -fx-background-radius: 12; -fx-padding: 20; -fx-border-color: #dbeafe; -fx-border-radius: 12;">
                     <children>
                        <HBox alignment="CENTER_LEFT" spacing="10.0">
                           <children>
                              <Circle radius="5.0" fill="#2563eb" />
                              <Label style="-fx-font-weight: bold; -fx-text-fill: #1e40af;" text="Analyse du Modèle IA" />
                           </children>
                        </HBox>
                        <Label fx:id="lblAiLabel" style="-fx-font-size: 16; -fx-font-weight: bold; -fx-text-fill: #1e3a8a;" text="Stress Modéré Détecté" />
                        <Label fx:id="lblAiRec" wrapText="true" style="-fx-text-fill: #1e40af; -fx-font-size: 13;" text="L'algorithme suggère une relaxation immédiate et une revue de la charge de travail hebdomadaire." />
                     </children>
                  </VBox>
               </children>
            </VBox>
         </content>
      </ScrollPane>

      <!-- Footer Actions -->
      <HBox alignment="CENTER_RIGHT" spacing="15.0" style="-fx-padding: 20; -fx-background-color: #f8fafc; -fx-border-color: #e2e8f0; -fx-border-width: 1 0 0 0; -fx-background-radius: 0 0 20 20;">
         <children>
            <Button onAction="#handleClose" style="-fx-background-color: transparent; -fx-text-fill: #64748b; -fx-font-weight: bold;" text="Fermer" />
            <Button fx:id="btnAction" style="-fx-background-color: #b91c1c; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10 25; -fx-background-radius: 8;" text="Signaler Situation" />
         </children>
      </HBox>
   </children>
</VBox>
