<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import java.util.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>
<?import javafx.scene.chart.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.image.Image?>

<AnchorPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.example.wellbeing.frontoffice.controller.WellbeingControllerClientController"
            prefHeight="600.0" prefWidth="800.0"
            style="-fx-background-color: #f4f7fa;">

    <StackPane fx:id="mainContainer" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
        
        <!-- Dashboard / List View -->
        <VBox fx:id="dashboardView" spacing="20.0" style="-fx-padding: 30;">
            <HBox alignment="CENTER_LEFT" spacing="20.0">
                <Label text="Mes Données de Bien-être" style="-fx-font-size: 28px; -fx-font-weight: 800; -fx-text-fill: #1e293b;" />
                <Region HBox.hgrow="ALWAYS" />
                <HBox spacing="10">
                    <Button text="🥗 Analyse de Repas" onAction="#showMealAnalysis" style="-fx-background-color: #6366f1; -fx-text-fill: white; -fx-font-weight: 700; -fx-padding: 10 20; -fx-background-radius: 10; -fx-cursor: hand;" />
                    <Button text="+ Évaluer mon bien-être" onAction="#showForm" style="-fx-background-color: #28a745; -fx-text-fill: white; -fx-font-weight: 700; -fx-padding: 10 20; -fx-background-radius: 10; -fx-cursor: hand;" />
                </HBox>
            </HBox>
            
            <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-color: transparent;" VBox.vgrow="ALWAYS">
                <VBox spacing="30.0">
                    <!-- Stress Evaluations Section -->
                    <VBox spacing="15.0">
                        <FlowPane fx:id="cardsContainer" hgap="20.0" vgap="20.0" style="-fx-padding: 5;" />
                    </VBox>

                    <!-- Banner Section -->
                    <HBox alignment="CENTER_LEFT" spacing="20" style="-fx-background-color: linear-gradient(to right, #6366f1, #8b5cf6); -fx-background-radius: 15; -fx-padding: 20;">
                        <VBox spacing="5" HBox.hgrow="ALWAYS">
                            <Label text="Detailed Analysis Available" style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: 800;" />
                            <Label text="Visualize your well-being trends over time." style="-fx-text-fill: rgba(255,255,255,0.8); -fx-font-size: 13px;" />
                        </VBox>
                        <Button text="View Stress Statistics ›" style="-fx-background-color: white; -fx-text-fill: #6366f1; -fx-font-weight: 700; -fx-padding: 10 20; -fx-background-radius: 10; -fx-cursor: hand;" />
                    </HBox>

                    <!-- Meals Section -->
                    <VBox spacing="15.0">
                        <HBox alignment="CENTER_LEFT" spacing="15">
                            <Label text="My Meals" style="-fx-font-size: 22px; -fx-font-weight: 800; -fx-text-fill: #1e293b;" />
                            <Region HBox.hgrow="ALWAYS" />
                            <HBox spacing="10" alignment="CENTER_RIGHT">
                                <TextField fx:id="searchField" promptText="🔍 Rechercher un repas..." style="-fx-background-radius: 10; -fx-background-color: white; -fx-border-color: #e2e8f0; -fx-border-radius: 10; -fx-padding: 8 12; -fx-pref-width: 200;" />
                                <ComboBox fx:id="filterCombo" promptText="Filtrer par calories" style="-fx-background-radius: 10; -fx-background-color: white; -fx-border-color: #e2e8f0; -fx-border-radius: 10; -fx-padding: 5;" />
                                <Button text="🍽 Add Meal" onAction="#showMealAnalysis" style="-fx-background-color: #10b981; -fx-text-fill: white; -fx-font-weight: 700; -fx-padding: 8 15; -fx-background-radius: 8; -fx-cursor: hand;" />
                            </HBox>
                        </HBox>
                        <FlowPane fx:id="mealsContainer" hgap="20.0" vgap="20.0" style="-fx-padding: 5;" />
                    </VBox>

                    <!-- Statistics Section -->
                    <VBox spacing="20.0">
                        <HBox alignment="CENTER_LEFT">
                            <Label text="Mes Statistiques" style="-fx-font-size: 22px; -fx-font-weight: 800; -fx-text-fill: #1e293b;" />
                        </HBox>
                        
                        <!-- Large Stress Trend -->
                        <VBox spacing="10" style="-fx-background-color: white; -fx-background-radius: 20; -fx-padding: 25; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 15, 0, 0, 10);">
                            <VBox spacing="4">
                                <HBox alignment="CENTER_LEFT">
                                    <Label text="📈 Stress Score Trend" style="-fx-font-size: 16px; -fx-font-weight: 800; -fx-text-fill: #1e293b;" />
                                    <Region HBox.hgrow="ALWAYS" />
                                    <VBox alignment="CENTER_RIGHT" spacing="2">
                                        <Label fx:id="lblCurrentStress" text="--" style="-fx-font-size: 18px; -fx-font-weight: 900; -fx-text-fill: #6366f1;" />
                                        <Label text="Dernier Score" style="-fx-font-size: 9px; -fx-text-fill: #94a3b8; -fx-text-transform: uppercase;" />
                                    </VBox>
                                    <Region prefWidth="20" />
                                    <HBox spacing="15">
                                        <HBox alignment="CENTER" spacing="5">
                                            <Circle radius="4" fill="#10b981" />
                                            <Label text="Low" style="-fx-font-size: 11px; -fx-text-fill: #64748b;" />
                                        </HBox>
                                        <HBox alignment="CENTER" spacing="5">
                                            <Circle radius="4" fill="#f59e0b" />
                                            <Label text="Moderate" style="-fx-font-size: 11px; -fx-text-fill: #64748b;" />
                                        </HBox>
                                        <HBox alignment="CENTER" spacing="5">
                                            <Circle radius="4" fill="#ef4444" />
                                            <Label text="High" style="-fx-font-size: 11px; -fx-text-fill: #64748b;" />
                                        </HBox>
                                    </HBox>
                                </HBox>
                                <Label text="Évolution de votre niveau de stress global basé sur vos évaluations quotidiennes." style="-fx-font-size: 11px; -fx-text-fill: #64748b;" />
                            </VBox>
                            <AreaChart fx:id="stressTrendChart" prefHeight="300" legendSide="TOP" legendVisible="false" styleClass="premium-chart">
                                <xAxis><CategoryAxis side="BOTTOM" /></xAxis>
                                <yAxis><NumberAxis side="LEFT" lowerBound="0" upperBound="100" tickUnit="20" /></yAxis>
                            </AreaChart>
                        </VBox>

                        <!-- Smaller Charts Grid -->
                        <HBox spacing="20">
                            <!-- Mood Trends -->
                            <VBox spacing="10" HBox.hgrow="ALWAYS" style="-fx-background-color: white; -fx-background-radius: 20; -fx-padding: 20; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 15, 0, 0, 10);">
                                <VBox spacing="4">
                                    <HBox alignment="CENTER_LEFT">
                                        <Label text="📉 Mood Trends" style="-fx-font-size: 14px; -fx-font-weight: 800; -fx-text-fill: #1e293b;" />
                                        <Region HBox.hgrow="ALWAYS" />
                                        <Label fx:id="lblMoodStatus" text="--" style="-fx-font-size: 12px; -fx-font-weight: 800; -fx-text-fill: #3b82f6;" />
                                    </HBox>
                                    <Label text="Suivi de l'anxiété et irritabilité." style="-fx-font-size: 10px; -fx-text-fill: #64748b;" wrapText="true" />
                                </VBox>
                                <LineChart fx:id="moodTrendChart" prefHeight="200" legendVisible="false" styleClass="small-premium-chart">
                                    <xAxis><CategoryAxis side="BOTTOM" /></xAxis>
                                    <yAxis><NumberAxis side="LEFT" lowerBound="0" upperBound="5" tickUnit="1" /></yAxis>
                                </LineChart>
                            </VBox>
                            
                            <!-- Calorie History -->
                            <VBox spacing="10" HBox.hgrow="ALWAYS" style="-fx-background-color: white; -fx-background-radius: 20; -fx-padding: 20; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 15, 0, 0, 10);">
                                <VBox spacing="4">
                                    <HBox alignment="CENTER_LEFT">
                                        <Label text="🔥 Calorie History" style="-fx-font-size: 14px; -fx-font-weight: 800; -fx-text-fill: #1e293b;" />
                                        <Region HBox.hgrow="ALWAYS" />
                                        <Label fx:id="lblTodayCalories" text="0 kcal" style="-fx-font-size: 12px; -fx-font-weight: 800; -fx-text-fill: #10b981;" />
                                    </HBox>
                                    <Label text="Apport calorique journalier." style="-fx-font-size: 10px; -fx-text-fill: #64748b;" wrapText="true" />
                                </VBox>
                                <BarChart fx:id="calorieChart" prefHeight="200" legendVisible="false" styleClass="small-premium-chart">
                                    <xAxis><CategoryAxis side="BOTTOM" /></xAxis>
                                    <yAxis><NumberAxis side="LEFT" label="kcal" /></yAxis>
                                </BarChart>
                            </VBox>

                            <!-- Log Frequency -->
                            <VBox spacing="10" HBox.hgrow="ALWAYS" style="-fx-background-color: white; -fx-background-radius: 20; -fx-padding: 20; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 15, 0, 0, 10);">
                                <VBox spacing="4">
                                    <HBox alignment="CENTER_LEFT">
                                        <Label text="📅 Log Frequency" style="-fx-font-size: 14px; -fx-font-weight: 800; -fx-text-fill: #1e293b;" />
                                        <Region HBox.hgrow="ALWAYS" />
                                        <Label fx:id="lblTotalLogs" text="-- logs" style="-fx-font-size: 12px; -fx-font-weight: 800; -fx-text-fill: #8b5cf6;" />
                                    </HBox>
                                    <Label text="Assiduité (Évaluations + Repas)." style="-fx-font-size: 10px; -fx-text-fill: #64748b;" wrapText="true" />
                                </VBox>
                                <BarChart fx:id="frequencyChart" prefHeight="200" legendVisible="false" styleClass="small-premium-chart">
                                    <xAxis><CategoryAxis side="BOTTOM" /></xAxis>
                                    <yAxis><NumberAxis side="LEFT" label="Entries" /></yAxis>
                                </BarChart>
                            </VBox>
                        </HBox>
                    </VBox>
                </VBox>
            </ScrollPane>

        </VBox>

        <!-- Evaluation Form View (Initially Hidden) -->
        <ScrollPane fx:id="formView" fitToWidth="true" visible="false" style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-color: transparent;">
            <content>
                <VBox alignment="TOP_CENTER" spacing="30.0" style="-fx-padding: 40;">
                    
                    <HBox alignment="CENTER_LEFT">
                        <Button text="← Retour" onAction="#showDashboard" style="-fx-background-color: #6c757d; -fx-text-fill: white; -fx-padding: 8 15; -fx-background-radius: 8; -fx-cursor: hand;" />
                    </HBox>

                    <!-- Header Section -->
                    <VBox alignment="CENTER" spacing="10.0">
                        <Label text="Évaluation du Bien-être" style="-fx-font-size: 36px; -fx-font-weight: 900; -fx-text-fill: #0f172a; -fx-letter-spacing: -1px;" />
                        <Label text="Glissez les curseurs selon votre ressenti actuel. Plus vous allez vers la droite, plus le niveau est élevé." style="-fx-font-size: 16px; -fx-text-fill: #64748b;" textAlignment="CENTER" wrapText="true" maxWidth="600" />
                    </VBox>

                    <!-- Form Card -->
                    <VBox spacing="25.0" style="-fx-background-color: white; -fx-background-radius: 30; -fx-padding: 40; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 30, 0, 0, 15);" maxWidth="700">
                        
                        <Label text="Indicateurs de Vie" style="-fx-font-size: 20px; -fx-font-weight: 800; -fx-text-fill: #dc3545;" />

                        <GridPane hgap="30.0" vgap="35.0">
                            <columnConstraints>
                                <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" percentWidth="50.0" />
                                <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" percentWidth="50.0" />
                            </columnConstraints>
                            
                            <!-- Helper Macro for Slider with Guides -->
                            <!-- Environment Work -->
                            <VBox spacing="8.0" GridPane.columnIndex="0" GridPane.rowIndex="0">
                                <Label text="Environnement de travail" style="-fx-font-weight: 700; -fx-text-fill: #1e293b;" />
                                <Slider fx:id="sldWorkEnvironment" min="1" max="5" value="3" majorTickUnit="1" minorTickCount="0" snapToTicks="true" />
                                <HBox spacing="10">
                                    <Label text="Calme" style="-fx-font-size: 10px; -fx-text-fill: #94a3b8;" />
                                    <Region HBox.hgrow="ALWAYS" />
                                    <Label text="Stressant" style="-fx-font-size: 10px; -fx-text-fill: #94a3b8;" />
                                </HBox>
                            </VBox>

                            <!-- Sleep Problems -->
                            <VBox spacing="8.0" GridPane.columnIndex="1" GridPane.rowIndex="0">
                                <Label text="Problèmes de sommeil" style="-fx-font-weight: 700; -fx-text-fill: #1e293b;" />
                                <Slider fx:id="sldSleepProblems" min="1" max="5" value="3" majorTickUnit="1" minorTickCount="0" snapToTicks="true" />
                                <HBox spacing="10">
                                    <Label text="Aucun" style="-fx-font-size: 10px; -fx-text-fill: #94a3b8;" />
                                    <Region HBox.hgrow="ALWAYS" />
                                    <Label text="Sévères" style="-fx-font-size: 10px; -fx-text-fill: #94a3b8;" />
                                </HBox>
                            </VBox>

                            <!-- Headaches -->
                            <VBox spacing="8.0" GridPane.columnIndex="0" GridPane.rowIndex="1">
                                <Label text="Maux de tête" style="-fx-font-weight: 700; -fx-text-fill: #1e293b;" />
                                <Slider fx:id="sldHeadaches" min="1" max="5" value="3" majorTickUnit="1" minorTickCount="0" snapToTicks="true" />
                                <HBox spacing="10">
                                    <Label text="Jamais" style="-fx-font-size: 10px; -fx-text-fill: #94a3b8;" />
                                    <Region HBox.hgrow="ALWAYS" />
                                    <Label text="Fréquents" style="-fx-font-size: 10px; -fx-text-fill: #94a3b8;" />
                                </HBox>
                            </VBox>

                            <!-- Restlessness -->
                            <VBox spacing="8.0" GridPane.columnIndex="1" GridPane.rowIndex="1">
                                <Label text="Agitation / Nervosité" style="-fx-font-weight: 700; -fx-text-fill: #1e293b;" />
                                <Slider fx:id="sldRestlessness" min="1" max="5" value="3" majorTickUnit="1" minorTickCount="0" snapToTicks="true" />
                                <HBox spacing="10">
                                    <Label text="Zen" style="-fx-font-size: 10px; -fx-text-fill: #94a3b8;" />
                                    <Region HBox.hgrow="ALWAYS" />
                                    <Label text="Agité" style="-fx-font-size: 10px; -fx-text-fill: #94a3b8;" />
                                </HBox>
                            </VBox>

                             <!-- Heartbeat Palpitations -->
                             <VBox spacing="8.0" GridPane.columnIndex="0" GridPane.rowIndex="2">
                                <Label text="Palpitations cardiaques" style="-fx-font-weight: 700; -fx-text-fill: #1e293b;" />
                                <Slider fx:id="sldHeartbeatPalpitations" min="1" max="5" value="3" majorTickUnit="1" minorTickCount="0" snapToTicks="true" />
                                <HBox spacing="10">
                                    <Label text="Normal" style="-fx-font-size: 10px; -fx-text-fill: #94a3b8;" />
                                    <Region HBox.hgrow="ALWAYS" />
                                    <Label text="Palpitations" style="-fx-font-size: 10px; -fx-text-fill: #94a3b8;" />
                                </HBox>
                            </VBox>

                            <!-- Low Academic Confidence -->
                            <VBox spacing="8.0" GridPane.columnIndex="1" GridPane.rowIndex="2">
                                <Label text="Confiance académique" style="-fx-font-weight: 700; -fx-text-fill: #1e293b;" />
                                <Slider fx:id="sldLowAcademicConfidence" min="1" max="5" value="3" majorTickUnit="1" minorTickCount="0" snapToTicks="true" />
                                <HBox spacing="10">
                                    <Label text="Confiant" style="-fx-font-size: 10px; -fx-text-fill: #94a3b8;" />
                                    <Region HBox.hgrow="ALWAYS" />
                                    <Label text="Incertain" style="-fx-font-size: 10px; -fx-text-fill: #94a3b8;" />
                                </HBox>
                            </VBox>

                            <!-- Class Attendance -->
                            <VBox spacing="8.0" GridPane.columnIndex="0" GridPane.rowIndex="3">
                                <Label text="Assiduité aux cours" style="-fx-font-weight: 700; -fx-text-fill: #1e293b;" />
                                <Slider fx:id="sldClassAttendance" min="1" max="5" value="3" majorTickUnit="1" minorTickCount="0" snapToTicks="true" />
                                <HBox spacing="10">
                                    <Label text="Présent" style="-fx-font-size: 10px; -fx-text-fill: #94a3b8;" />
                                    <Region HBox.hgrow="ALWAYS" />
                                    <Label text="Absentéisme" style="-fx-font-size: 10px; -fx-text-fill: #94a3b8;" />
                                </HBox>
                            </VBox>

                            <!-- Anxiety Tension -->
                            <VBox spacing="8.0" GridPane.columnIndex="1" GridPane.rowIndex="3">
                                <Label text="Tension anxieuse" style="-fx-font-weight: 700; -fx-text-fill: #1e293b;" />
                                <Slider fx:id="sldAnxietyTension" min="1" max="5" value="3" majorTickUnit="1" minorTickCount="0" snapToTicks="true" />
                                <HBox spacing="10">
                                    <Label text="Relâché" style="-fx-font-size: 10px; -fx-text-fill: #94a3b8;" />
                                    <Region HBox.hgrow="ALWAYS" />
                                    <Label text="Tendu" style="-fx-font-size: 10px; -fx-text-fill: #94a3b8;" />
                                </HBox>
                            </VBox>

                            <!-- Irritability -->
                            <VBox spacing="8.0" GridPane.columnIndex="0" GridPane.rowIndex="4">
                                <Label text="Irritabilité" style="-fx-font-weight: 700; -fx-text-fill: #1e293b;" />
                                <Slider fx:id="sldIrritability" min="1" max="5" value="3" majorTickUnit="1" minorTickCount="0" snapToTicks="true" />
                                <HBox spacing="10">
                                    <Label text="Patient" style="-fx-font-size: 10px; -fx-text-fill: #94a3b8;" />
                                    <Region HBox.hgrow="ALWAYS" />
                                    <Label text="Irritable" style="-fx-font-size: 10px; -fx-text-fill: #94a3b8;" />
                                </HBox>
                            </VBox>

                            <!-- Subject Confidence -->
                            <VBox spacing="8.0" GridPane.columnIndex="1" GridPane.rowIndex="4">
                                <Label text="Confiance dans les sujets" style="-fx-font-weight: 700; -fx-text-fill: #1e293b;" />
                                <Slider fx:id="sldSubjectConfidence" min="1" max="5" value="3" majorTickUnit="1" minorTickCount="0" snapToTicks="true" />
                                <HBox spacing="10">
                                    <Label text="Maîtrise" style="-fx-font-size: 10px; -fx-text-fill: #94a3b8;" />
                                    <Region HBox.hgrow="ALWAYS" />
                                    <Label text="Difficulté" style="-fx-font-size: 10px; -fx-text-fill: #94a3b8;" />
                                </HBox>
                            </VBox>
                        </GridPane>

                        <HBox alignment="CENTER" style="-fx-padding: 10 0 0 0;">
                            <Button text="Enregistrer mes données" onAction="#handleSubmit" style="-fx-background-color: #28a745; -fx-text-fill: white; -fx-font-weight: 800; -fx-font-size: 16px; -fx-padding: 15 40; -fx-background-radius: 20; -fx-cursor: hand; -fx-effect: dropshadow(three-pass-box, rgba(40, 167, 69, 0.3), 15, 0, 0, 8);" />
                        </HBox>
                    </VBox>

                </VBox>
            </content>
        </ScrollPane>

        <!-- Meal Analysis View (Initially Hidden) -->
        <VBox fx:id="mealViewContainer" visible="false" style="-fx-background-color: #f8fafc;">
            <HBox alignment="CENTER_LEFT" style="-fx-padding: 20 40 0 40;">
                <Button text="← Retour" onAction="#showDashboard" style="-fx-background-color: #6c757d; -fx-text-fill: white; -fx-padding: 8 15; -fx-background-radius: 8; -fx-cursor: hand;" />
            </HBox>
            <StackPane fx:id="mealContentArea" VBox.vgrow="ALWAYS" />
        </VBox>

    </StackPane>

    <!-- Chatbot Window -->
    <VBox fx:id="chatbotContainer" visible="false" managed="true" 
          AnchorPane.bottomAnchor="100.0" AnchorPane.rightAnchor="30.0" 
          prefWidth="400.0" prefHeight="600.0" maxWidth="400" maxHeight="600"
          style="-fx-background-color: transparent;">
    </VBox>
    
    <!-- Chatbot Floating Action Area -->
    <StackPane AnchorPane.bottomAnchor="30.0" AnchorPane.rightAnchor="30.0">
        <children>
            <!-- Floating Bubble Button -->
            <Button fx:id="chatbotButton" onAction="#toggleChatbot" styleClass="floating-chat-bubble">
                <graphic>
                    <ImageView fitHeight="35.0" fitWidth="35.0" pickOnBounds="true" preserveRatio="true">
                        <image>
                            <Image url="@../../assets/images/chatboticon.png" />
                        </image>
                    </ImageView>
                </graphic>
            </Button>
            
            <!-- Notification Badge -->
            <Circle fx:id="chatbotBadge" fill="#ff4757" radius="8.0" stroke="WHITE" strokeType="INSIDE" strokeWidth="2.0" visible="false" StackPane.alignment="TOP_RIGHT">
                <StackPane.margin>
                    <Insets right="5.0" top="5.0" />
                </StackPane.margin>
            </Circle>
        </children>
    </StackPane>
</AnchorPane>
